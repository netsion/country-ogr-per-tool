  "political_stances": [
    "支持加强国防网络安全建设，建议国防部成立'数字化军团'以应对跨境网络战争威胁",
    "呼吁国会停止政治对立，专注讨论关系国计民生的国家议题",
    "积极推动TVET（技术与职业教育培训）发展，支持政府预算中79亿令吉TVET拨款",
    "支持马来西亚与中国的教育和经济合作，担任马中研究所咨询委员会主席",
    "支持团结政府理念，呼吁选民在补选中支持国阵以保持与州政府一致",
    "关注FELDA垦殖区居民和小园主福祉，主张提升橡胶废料生物柴油研究以降低柴油价格",
    "支持RISDA成为小园主橡胶的唯一收购商，保障小园主收入",
    "关注叙利亚局势，支持马来西亚基于主权原则的外交立场"
  ],
