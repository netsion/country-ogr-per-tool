  "political_stances": [
    "\u575a\u5b9a\u652f\u6301\u6c99\u5df4\u6839\u636e\u9a6c\u6765\u897f\u4e9a\u534f\u5b9a1963\uff08MA63\uff09\u4eab\u6709\u8054\u90a6\u51c0\u6536\u5165\u768440%\u7279\u522b\u62e8\u6b3e\u6743\u5229\uff0c\u591a\u6b21\u53d1\u58f0\u656c\u4fc3\u8054\u90a6\u653f\u5e9c\u5c3d\u5feb\u5b9e\u65bd",
    "\u4e3b\u5f20\u6c99\u5df4\u548c\u7802\u62c9\u8d8a\u5728\u56fd\u4f1a\u7684\u5e73\u7b49\u4ee3\u8868\u6743\u4e0d\u5e94\u4ec5\u57fa\u4e8e\u4eba\u53e3\u6570\u91cf\uff0c\u800c\u662f\u9a6c\u6765\u897f\u4e9a\u8054\u90a6\u5236\u7684\u57fa\u7840\u6027\u4fdd\u8bc1",
    "\u652f\u6301\u201c\u6c99\u5df4\u4eba\u6cbb\u7406\u6c99\u5df4\u201d\u653f\u7b56\uff0c\u4e3b\u5f20\u6c99\u5df4\u5e94\u6709\u81ea\u4e3b\u7ba1\u7406\u672c\u5dde\u4e8b\u52a1\u7684\u6743\u5229",
    "\u652f\u6301GRS\u653f\u5e9c\u7ef4\u62a4\u9650\u5236\u897f\u9a6c\u6765\u4eba\u8fdb\u5165\u6c99\u5df4\u7684\u6761\u4ef6\uff0c\u8ba4\u4e3a\u8fd9\u662fMA63\u4fdd\u969c\u7684\u6743\u5229",
    "\u4e3b\u5f20\u4fdd\u62a4\u6c99\u5df4\u548c\u7802\u62c9\u8d8a\u7684\u6cb9\u68d5\u4ea7\u4e1a\u514d\u53d7\u503e\u9500\u5a01\u80c1\uff0c\u5e76\u5c06\u4fdd\u62a4\u8303\u56f4\u6269\u5c55\u81f3\u6cb9\u8102\u5316\u5de5\u548c\u751f\u7269\u8d28\u7b49\u4e0b\u6e38\u4ea7\u4e1a",
    "\u901a\u8fc7\u6a59\u80f6\u79cd\u690d\u8ba1\u5212\u548c\u8ff7\u4f60\u79cd\u690d\u56ed\uff08MESEJ\uff09\u9879\u76ee\u63a8\u52a8\u6c99\u5df4\u6276\u8d2b\u548c\u7ecf\u6d4e\u53d1\u5c55"
  ],
  "major_achievements": [
    "\u4efb\u5185\u5e26\u9886\u6c99\u5df4\u6a59\u80f6\u4ea7\u4e1a\u59d4\u5458\u4f1a\uff08LIGS\uff09\u5411\u5dde\u653f\u5e9c\u8d21\u732e\u8d85\u8fc7RM280\u4e07\uff082021\u5e74RM130\u4e07\uff0c2022\u5e74RM150\u4e07\uff09",
    "\u4e3b\u5bfcLIGS\u4e3a\u6c99\u5df4\u7ea686,503\u540d\u6a59\u80f6\u5c0f\u4e1a\u4e3b\u53d1\u653e\u5f00\u6597\u8282\u7279\u522b\u63f4\u52a9\u91d1\uff08RM1730\u4e07\uff09",
    "\u901a\u8fc7\u96c6\u4f53\u6a59\u80f6\u79cd\u690d\u8ba1\u5212\u63a8\u52a8\u6c99\u5df4\u6d88\u9664\u8d2b\u56f0",
    "\u4f5c\u4e3aSTAR\u79d8\u4e66\u957f\u548c\u7b56\u7565\u4e3b\u4efb\uff0c\u63a8\u52a8PBS\u4e0eSTAR\u5408\u4f5c\u4e0e\u5408\u5e76\u8c08\u5224",
    "\u4e8e2024\u5e7412\u6708\u5ba3\u8a93\u5c31\u4efb\u4e0a\u8bae\u9662\u8bae\u5458\uff0c\u4ee3\u8868\u6c99\u5df4\u5728\u8054\u90a6\u5c42\u9762\u53d1\u58f0"
  ],
  "biography_summary": "Datuk Edward Linggu Bukut\uff08\u539f\u540dLinggu @ Edward bin Bukut\uff09\uff0c1958\u5e7412\u670820\u65e5\u51fa\u751f\u4e8e\u6c99\u5df4Tamparuli\uff0c\u5361\u8fbe\u5c71\u675c\u987a\u65cf\u88d4\u653f\u6cbb\u5bb6\u3002\u73b0\u4efb\u9a6c\u6765\u897f\u4e0a\u8bae\u9662\u8bae\u5458\uff082024\u5e7412\u670810\u65e5\u81f32027\u5e7412\u67089\u65e5\uff09\uff0c\u7531\u6c99\u5df4\u5dde\u7acb\u6cd5\u8bae\u4f1a\u9009\u51fa\u3002\u6c99\u5df4\u7acb\u65b0\u515a\uff08STAR/\u6c99\u5df4\u7acb\u65b0\u515a\uff09\u526f\u4e3b\u5e2d\u517c\u79d8\u4e66\u957f\u3002\u66fe\u4efb\u6c99\u5df4\u5dde\u7acb\u6cd5\u8bae\u4f1aTamparuli\u9009\u533a\u8bae\u5458\uff081999-2004\uff09\u3001\u6c99\u5df4\u4fe1\u8d37\u516c\u53f8\u4e3b\u5e2d\u3001\u6c99\u5df4\u6a59\u80f6\u4ea7\u4e1a\u59d4\u5458\u4f1a\uff08LIGS\uff09\u4e3b\u5e2d\u3002\u653f\u6cbb\u5386\u7a0b\uff1a\u65e9\u671f\u4e3aPBS\u515a\u5458\uff0c2001\u5e74\u968fJeffrey Kitingan\u8f6c\u6295PBRS\uff0c\u540e\u52a0\u5165STAR\u5e76\u5148\u540e\u62c5\u4efb\u526f\u4e3b\u5e2d\uff082018-2021\uff09\u548c\u79d8\u4e66\u957f\uff082021\u81f3\u4eca\uff09\u30022025\u5e7412\u6708\u8d77\u5347\u4efbSTAR\u526f\u4e3b\u5e2d\u3002\u83b7\u5f97\u6c99\u5df4\u5dde\u52a0\u96c5\u5c71\u52cb\u7ae0\u4e8c\u7ea7\u529f\u52cb\u52cb\u7ae0\uff08PGDK-Datuk\uff0c2022\uff09\u3001\u4f34\u4fa3\u52cb\u7ae0\uff08ASDK\uff0c2006\uff09\u548c\u592a\u5e73\u5c40\u7ec5\uff08JP\uff0c2020\uff09\u3002\u575a\u5b9a\u4e3b\u5f20\u6c99\u5df4\u5728MA63\u6846\u67b6\u4e0b\u7684\u6743\u5229\uff0c\u7279\u522b\u662f40%\u51c0\u6536\u5165\u7279\u522b\u62e8\u6b3e\u3001\u5e73\u7b49\u56fd\u4f1a\u4ee3\u8868\u6743\u548c\u6c99\u5df4\u81ea\u4e3b\u7ba1\u7406\u6743\u3002",
