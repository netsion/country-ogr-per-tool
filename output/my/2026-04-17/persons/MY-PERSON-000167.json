  "political_stances": [
    "\u4e3b\u5f20\u6253\u51fb\u8150\u8d25\u5e94\u66f4\u52a0\u5168\u9762\u548c\u5f7b\u5e95\uff0c\u8ba4\u4e3a\u8150\u8d25\u5f71\u54cd\u56fd\u5bb6\u5b89\u5168\u3001\u5236\u5ea6\u4e3b\u6743\u548c\u516c\u4f17\u4fe1\u4efb",
    "\u652f\u6301\u5baa\u6cd5\u4fee\u6b63\u6848\u4ee5\u89e3\u51b3\u516c\u6c11\u6743\u95ee\u9898\uff0c\u5305\u62ec\u5973\u6027\u516c\u6c11\u6743\u65b9\u9762\u7684\u5e73\u7b49\u6743\u5229",
    "\u79ef\u6781\u63a8\u52a8Perlis\u6210\u4e3a\u56fd\u9645\u6e05\u771f\u7269\u6d41\u67a2\u7ebd\uff0c\u5efa\u8bbePadang Besar\u4e3a\u8fb9\u5883\u7ecf\u6d4e\u53d1\u5c55\u4e2d\u5fc3",
    "\u5173\u6ce8\u8fb9\u5883\u5b89\u5168\u95ee\u9898\uff0c\u652f\u6301\u52a0\u5f3a\u9a6c\u6cf0\u8fb9\u5883\u56f4\u5899\u5efa\u8bbe\u4ee5\u6253\u51fb\u975e\u6cd5\u8d8a\u5883",
    "\u5021\u5bfc\u53d1\u5c55TVET\u6280\u672f\u6559\u80b2\u548c\u57f9\u8bad\uff0c\u7279\u522b\u662f\u4e3a\u5854\u592b\u91cc\u5b66\u751f\u63d0\u4f9b\u66f4\u9ad8\u5c42\u6b21\u7684\u5b66\u4e60\u673a\u4f1a",
    "\u63a8\u52a8Perlis\u65e0\u4eba\u673a\u6d4b\u8bd5\u548c\u7814\u7a76\u67a2\u7ebd\u5efa\u8bbe",
    "\u5173\u6ce8\u5c31\u4e1a\u5b89\u5168\u4e0e\u804c\u4e1a\u5065\u5eb7\u95ee\u9898"
  ],
  "major_achievements": [
    "2022\u5e74\u5927\u9009\u4e2d\u4ee553.58%\u5f97\u7968\u7387\uff0824,267\u7968\uff09\u51fb\u8d25\u591a\u540d\u5019\u9009\u4eba\uff0c\u591a\u6570\u7968\u8fbe12,514\u7968\uff0c\u4e3a\u56fd\u6c11\u8054\u76df(PN)\u593a\u4e0bPadang Besar\u5e2d\u4f4d",
    "\u53d1\u8d77Perlis4BorderTrade\u5916\u4ea4\u4e0e\u7ecf\u6d4e\u4f7f\u547d\uff0c\u5e26\u9886\u7ecf\u8d38\u56e2\u4f53\u8bbf\u95ee\u6cf0\u56fd\u5357\u90e8\uff0c\u4fc3\u8fdb\u8de8\u5883\u8d38\u6613\u5408\u4f5c",
    "\u5728Padang Besar\u53d1\u8d77\u591a\u9879\u793e\u533a\u9879\u76ee\uff0c\u5305\u62ecExcellent Centre TVET\u57f9\u8bad\u4e2d\u5fc3\u3001Asnaf\u65e9\u9910\u8ba1\u5212\u3001\u6148\u5584\u5065\u5eb7\u4e2d\u5fc3",
    "\u79ef\u6781\u63a8\u52a8Chuping Valley Industrial Area(CVIA)\u4ee5\u53caPadang Besar\u8fc7\u5883\u5bfc\u5411\u5f00\u53d1(TOD)\u9879\u76ee",
    "\u62c5\u4efb\u56fd\u4f1a\u4e0b\u8bae\u9662\u53ef\u6301\u7eed\u53d1\u5c55\u76ee\u6807\u5168\u8bae\u5458\u5e03\u6743\u5c0f\u7ec4(APPGM-SDG)\u59d4\u5458",
