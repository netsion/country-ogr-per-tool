  "political_stances": [
    "\u652f\u6301\u5df4\u52d2\u65af\u5766\u4eba\u6c11\u6743\u5229\uff0c\u66fe\u5728\u4e0a\u8bae\u9662\u63d0\u51fa\u5df4\u4ee5\u51b2\u7a81\u7d27\u6025\u52a8\u8bae\uff0c\u6562\u4e8e\u8d28\u8be2\u653f\u5e9c\u5bf9\u4ee5\u8272\u5217\u884c\u4e3a\u7684\u5e94\u5bf9\u63aa\u65bd",
    "\u5173\u6ce8\u4e2d\u56fd\u519b\u4e8b\u529b\u91cf\u5728\u9a6c\u6765\u897f\u4e9a\u7684\u5f71\u54cd\uff0c\u66fe\u5728\u4e0a\u8bae\u9662\u5c31\u4e2d\u56fd\u6d77\u519b\u5b66\u5458\u8bbf\u95ee\u69fd\u57ce\u534e\u6587\u5b66\u6821\u4e8b\u4ef6\u63d0\u51fa\u8d28\u8be2",
    "\u5173\u6ce8\u56fd\u5bb6\u8d22\u653f\u7eaa\u5f8b\u4e0e\u56fd\u503a\u95ee\u9898\uff0c\u66fe\u5728\u4e0a\u8bae\u9662\u5c31\u56fd\u5bb6\u503a\u52a1\u63d0\u51fa\u8865\u5145\u8d28\u8be2",
    "\u5173\u6ce8\u6cbf\u6d77\u4fb5\u8680\u5e94\u5bf9\u63aa\u65bd\uff0c\u66fe\u5c31\u6cbf\u6d77\u4fb5\u8680\u7d27\u6025\u57fa\u91d1\u5206\u914d\u63d0\u51fa\u8d28\u8be2",
    "\u5173\u6ce8\u671d\u89c9\u57fa\u91d1\u670d\u52a1\u6539\u5584\uff0c\u66fe\u8d28\u8be2\u671d\u89c9\u57fa\u91d1\u662f\u5426\u8ba1\u5212\u5728\u7981\u5bfa\u9644\u8fd1\u8d2d\u4e70\u571f\u5730\u4ee5\u6539\u5584\u671d\u89c9\u670d\u52a1",
    "\u5021\u5bfc\u4f0a\u65af\u5170\u6559\u4e49\u5728\u793e\u4f1a\u4e2d\u7684\u5b9e\u8df5\uff0c\u63a8\u52a8\u4f0a\u65af\u5170\u6559\u80b2\u548c\u53e4\u5170\u7ecf\u80cc\u8bf5\u4e8b\u4e1a"
  ],
  "major_achievements": [
    "\u521b\u7acb\u4f0a\u65af\u5170\u515a\u6148\u5584\u5fd7\u613f\u56e2\u4f53Unit Amal PAS\uff081988\u5e74\uff09\uff0c\u4e3a\u515a\u7684\u793e\u4f1a\u670d\u52a1\u4e8b\u4e1a\u5960\u5b9a\u57fa\u7840",
