    "\u83b7\u5f97\u767b\u5609\u697c\u5dde\u82cf\u4e39\u7c73\u8d5e\u00b7\u7956\u56e0\u00b7\u963f\u6bd4\u4e01\u52cb\u7ae0\uff08SMZ\uff0c2025\u5e74\uff09"
  ],
  "biography_summary": "\u4faf\u8f9b\u00b7\u4f0a\u65af\u8fc8\u5c14\uff0c1955\u5e745\u670810\u65e5\u751f\u4e8e\u767b\u5609\u697c\u5dde\u9a6c\u5170\uff0c\u9a6c\u6765\u897f\u4e9a\u4e0a\u8bae\u9662\u8bae\u5458\uff0c\u4f0a\u65af\u5170\u515a\uff08PAS\uff09\u5e74\u5ea6\u4ee3\u8868\u5927\u4f1a\u5e38\u52a1\u4e3b\u5e2d\u3002\u6bd5\u4e1a\u4e8e\u9a6c\u6765\u897f\u4e9a\u519c\u4e1a\u5927\u5b66\uff08\u73b0\u535a\u7279\u5927\u5b66\uff09\u79d1\u5b66\u4e0e\u6559\u80b2\u4e13\u4e1a\uff0c\u65e9\u5e74\u66fe\u4efb\u7406\u79d1\u6559\u5e08\uff0c\u540e\u8f6c\u5165\u4f01\u4e1a\u754c\u53ca\u4eba\u9053\u4e3b\u4e49\u4e8b\u4e1a\u30021988\u5e74\u521b\u7acb\u4f0a\u65af\u5170\u515a\u6148\u5584\u56e2\u4f53Unit Amal PAS\uff0c2001\u5e74\u521b\u7acb\u9a6c\u6765\u897f\u4e9a\u6148\u5584\u57fa\u91d1\u4f1a\u5e76\u4efb\u603b\u88c1\u81f3\u4eca\uff0c\u5e26\u9886\u4eba\u9053\u4e3b\u4e49\u63f4\u52a9\u4efb\u52a1\u8d85\u8fc740\u4e2a\u56fd\u5bb6\u30022012\u5e74\u8d77\u62c5\u4efb\u4f0a\u65af\u5170\u515a\u5e74\u5ea6\u4ee3\u8868\u5927\u4f1a\u5e38\u52a1\u4e3b\u5e2d\uff0c2023\u5e743\u6708\u7531\u767b\u5609\u697c\u5dde\u7acb\u6cd5\u8bae\u4f1a\u5168\u7968\u5f53\u9009\u4e3a\u4e0a\u8bae\u9662\u8bae\u5458\u3002\u59bb\u4e3a\u7f57\u65af\u7a46\u7eb3\u4f0a\u5a1c\u00b7\u52aa\u5c14\u00b7\u963f\u65af\u7a46\u5c3c\uff0c\u80b2\u6709\u4e5d\u540d\u5b50\u5973\uff0c\u5168\u90e8\u4e3a\u53e4\u5170\u7ecf\u80cc\u8bf5\u8005\u3002\u66fe\u83b7\u767b\u5609\u697c\u5dde\u5fd7\u613f\u8fc1\u5e45\u5178\u578b\u4eba\u7269\u5956\uff082020\uff09\u53ca\u82cf\u4e39\u7c73\u8d5e\u52cb\u7ae0\uff082025\uff09\u3002",
