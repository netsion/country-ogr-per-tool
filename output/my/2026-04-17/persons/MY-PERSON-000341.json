  "political_stances": [
    "支持社会健康保险制度（Social Health Insurance），推动马来西亚医疗融资改革",
    "主张废除合约医生制度，呼吁为医生提供永久职位",
    "推动医疗权力下放至砂拉越州，主张砂拉越应有自主的医疗预算和管理权",
    "支持烟草控制法案（Tobacco Control Bill），主张以公共卫生为导向的控烟政策",
    "主张维护1963年马来西亚协定（MA63）中砂拉越的权益",
    "反对种族政治，主张以全民共同利益为导向的政策",
    "支持民主制度和反对党角色，反对零反对派的州议会格局",
    "推动医疗体系改革，主张'健康融入所有政策'（Health in All Policies）理念",
    "关注砂拉越基础设施不足问题，呼吁改善清洁水源和道路建设",
    "支持提高医护人员值勤津贴和区域津贴（BIW）",
    "主张取消对物理治疗和传统与辅助医学征收销售服务税（SST）"
  ],
