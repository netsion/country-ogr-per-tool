  "political_stances": [
    "\u4e3b\u5f20\u653f\u5e9c\u5e94\u589e\u5efa\u66f4\u591a\u5b97\u6559\u5b66\u6821\uff0c\u8ba4\u4e3a\u5b97\u6559\u5b66\u6821\u5b66\u4e1a\u6210\u7ee9\u4f18\u4e8e\u4e16\u4fd7\u5b66\u6821",
    "\u5173\u6ce8\u519c\u6c11\u6743\u76ca\uff0c\u6279\u8bc4\u7c7b\u4f3c\u519c\u4e1a\u5361\u7279\u5c14\u5bf9\u519c\u6c11\u7684\u5265\u524a\uff0c\u8ba4\u4e3a\u519c\u6c11\u4e0d\u5e94\u6210\u4e3a\u5361\u7279\u5c14\u7684\u5960\u57fa",
    "\u5f3a\u8c03\u5e94\u52a0\u5f3a\u6280\u672f\u4e0e\u804c\u4e1a\u6559\u80b2\u57f9\u8bad\uff08TVET\uff09\u8bfe\u7a0b\uff0c\u4f7f\u5176\u4e0e\u7eff\u8272\u548c\u6570\u5b57\u6280\u672f\u7b49\u884c\u4e1a\u9700\u6c42\u5bf9\u63a5",
    "\u4e3b\u5f20\u4f53\u80b2\u5e94\u6210\u4e3a\u516c\u5f00\u8003\u8bd5\u7684\u5fc5\u4fee\u79d1\u76ee\uff0c\u6279\u8bc4\u5f53\u524d\u4f53\u80b2\u8bfe\u88ab\u8fb9\u7f18\u5316",
    "\u5173\u6ce8\u7cae\u98df\u5b89\u5168\u95ee\u9898\uff0c\u5c31\u653f\u5e9c\u5e94\u5bf9\u6c34\u707e\u548c\u6c14\u5019\u53d8\u5316\u5f71\u54cd\u7684\u98df\u54c1\u4f9b\u5e94\u63d0\u51fa\u8d28\u8be2",
    "\u6279\u8bc4\u7b2c\u5341\u4e09\u9a6c\u6765\u897f\u4e9a\u8ba1\u5212\u4e2d\u672a\u5c06\u9a6c\u6765\u8bed\u5217\u4e3a\u6838\u5fc3\u79d1\u76ee\uff0c\u62c5\u5fe7\u82f1\u8bed\u88ab\u8fc7\u5ea6\u5f3a\u8c03\u800c\u5f31\u5316\u56fd\u8bed\u5730\u4f4d",
    "\u5173\u6ce8\u5b66\u6821\u5bbf\u820d\u7ba1\u7406\u5458\u5de5\u4f5c\u8d1f\u8377\u8fc7\u91cd\u95ee\u9898\uff0c\u547c\u5401\u6539\u5584\u5bbf\u820d\u7ba1\u7406"
  ],
  "major_achievements": [
    "2022\u5e74\u5927\u9009\u4e2d\u4ee524,562\u7968\uff0843.70%\uff09\u51fb\u8d25\u591a\u540d\u5019\u9009\u4eba\uff0c\u591a\u6570\u7968\u8fbe9,192\u7968\uff0c\u4e3aPN\u5f81\u5f97Kangar\u8bae\u5e2d",
