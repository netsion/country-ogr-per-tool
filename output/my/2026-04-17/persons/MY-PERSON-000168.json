    "\u4ee5\u524d\u6559\u5e08\u8eab\u4efd\u79ef\u6781\u5173\u6ce8\u6559\u80b2\u8bae\u9898\uff0c\u5728\u8bae\u4f1a\u4e2d\u5c31\u5b97\u6559\u5b66\u6821\u3001TVET\u3001\u4f53\u80b2\u6559\u80b2\u7b49\u8bae\u9898\u53d1\u8a00"
