  "political_stances": [
    "\u4e3b\u5f20\u63d0\u9ad8\u533b\u751f\u503c\u73ed\u6d25\u8d34\uff08on-call allowance\uff09\uff0c\u4eceRM9/\u5c0f\u65f6\u63d0\u9ad8\u81f3RM55-65/\u5c0f\u65f6",
    "\u63a8\u52a8\u4fee\u8ba2\u300a\u4eba\u4f53\u7ec4\u7ec7\u6cd5\u300b1974\uff0c\u4fc3\u8fdb\u5668\u5b98\u6350\u8d60\u5236\u5ea6\u6539\u9769",
    "\u5173\u6ce8\u8840\u6db2\u900f\u6790\u8d39\u7528\u5371\u673a\uff0c\u8b66\u544a\u81f32030\u5e74\u5e74\u8d39\u7528\u5c06\u8fbe40\u4ebf\u6797\u5409\u7279",
    "\u5021\u8bae\u5411\u6c99\u5df4\u548c\u7802\u62c9\u8d8a\u533b\u62a4\u4eba\u5458\u63d0\u4f9b\u7a0e\u52a1\u51cf\u514d\u548c\u6c7d\u8f66\u5173\u7a0e\u8c31\u514d\uff0c\u4ee5\u5438\u5f15\u533b\u62a4\u4eba\u624d",
    "\u7ef4\u62a4\u694a\u5dde\u5370\u5ea6\u6559\u5bfa\u5e99\u5b87\u6743\u76ca\uff0c\u8b66\u544a\u5916\u6765\u4eba\u58eb\u4e0d\u8981\u5e72\u6d89\u694a\u5dde\u5370\u5ea6\u6559\u4e8b\u52a1",
    "\u652f\u6301\u5e0c\u76df\uff08PH\uff09/\u6c11\u4e3b\u884c\u52a8\u515a\uff08DAP\uff09\u653f\u7eb2\uff0c\u652f\u6301\u201c\u660c\u660e\u5927\u9a6c\u201d\uff08MADANI\uff09\u653f\u5e9c\u65bd\u653f",
    "\u5173\u6ce8\u5370\u5ea6\u793e\u533a\u6559\u80b2\uff0c\u652f\u6301\u6de1\u7c73\u5c14\u5357\u8bed\u5c0f\u5b66\uff08SJKT\uff09\u53d1\u5c55",
    "\u4e3b\u5f20\u52a0\u5feb\u5408\u7ea6\u533b\u62a4\u4eba\u5458\u8f6c\u6b63\uff0c\u51cf\u5c11\u516c\u5171\u533b\u7597\u4eba\u624d\u6d41\u5931",
    "\u5173\u6ce8\u533b\u62a4\u4eba\u5458\u804c\u4e1a\u53d1\u5c55\uff0c\u4e3b\u5f20\u6539\u5584\u533b\u9662\u5de5\u4f5c\u73af\u5883\u548c\u664b\u5347\u673a\u5236"
  ],
  "major_achievements": [
    "\u7ee7\u627f\u7236\u4eb244\u5e74\u6148\u5584\u4f20\u7edf\uff0c\u6bcf\u5e74\u7ec4\u7ec7\u5370\u5ea6\u6559\u6392\u706f\u8282\uff08Deepavali\uff09\u6170\u95ee\u6d3b\u52a8\uff0c2025\u5e74\u6295\u516515\u4e07\u6797\u5409\u7279\u63f4\u52a9500\u4e2a\u5f31\u52bf\u5bb6\u5ead",
    "\u5411\u694a\u5dde\u9ad8\u7b49\u6559\u80b2\u673a\u6784\u5b66\u751f\u6350\u8d60100\u53f0\u7b14\u8bb0\u672c\u7535\u8111\uff0c\u4ef7\u503c20\u4e07\u6797\u5409\u7279",
    "\u4efb\u5185\u591a\u6b21\u5728\u4e0a\u8bae\u9662\u63d0\u51fa\u533b\u7597\u4f53\u5236\u6539\u9769\u63d0\u6848\uff0c\u5305\u62ec\u63d0\u9ad8\u503c\u73ed\u6d25\u8d34\u3001\u4fee\u8ba2\u5668\u5b98\u6350\u8d60\u6cd5\u3001\u6539\u5584\u533b\u62a4\u4eba\u5458\u5f85\u9047",
    "\u4efb\u694a\u5dde\u5370\u5ea6\u6559\u5bfa\u4e8b\u4e1a\u59d4\u5458\u4f1a\u526f\u4e3b\u5e2d\uff0c\u63a8\u52a8\u694a\u5dde\u5370\u5ea6\u6559\u793e\u533a\u798f\u7949\u548c\u6559\u80b2\u63f4\u52a9",
    "\u4ee3\u8868\u9a6c\u6765\u897f\u4e9a\u51fa\u5e2d2023\u5e74\u4e9a\u592a\u5730\u533a\u5168\u7403\u5065\u5eb7\u8986\u76d6\u533a\u57df\u5408\u4f5c\u4f1a\u8bae\uff08\u9a6c\u5c3c\u62c9\uff09"
  ],
  "biography_summary": "\u51cc\u683c\u65af\u74e6\u5170\u00b7\u963f\u9c81\u7eb3\u8428\u62c9\u59c6\uff08Dr. Lingeshwaran R. Arunasalam\uff09\uff0c1987\u5e74\u751f\uff0c\u9a6c\u6765\u897f\u4e9a\u5370\u88d4\u653f\u6cbb\u4eba\u7269\u548c\u533b\u751f\u3002\u6bd5\u4e1a\u4e8e\u97ad\u9706\u5dde\u7687\u5bb6\u533b\u5b66\u9662\uff08MBBS\uff09\uff0c\u540e\u53d6\u5f97\u65b0\u5357\u5a01\u5c14\u58eb\u5927\u5b66\u533b\u7597\u884c\u653f\u7855\u58eb\u548c\u53f0\u52d2\u5927\u5b66\u6cd5\u5b66\u7855\u58eb\u5b66\u4f4d\u3002\u66fe\u4efb\u53cc\u6eaa\u57f9\u533b\u9662\u9662\u957f\uff0c2023\u5e743\u6708\u7531\u694a\u5dde\u7acb\u6cd5\u8bae\u4f1a\u9009\u4e3a\u4e0a\u8bae\u9662\u8bae\u5458\uff0c\u4efb\u671f\u81f32026\u5e743\u6708\u3002\u4ed6\u662f\u6c11\u4e3b\u884c\u52a8\u515a\uff08DAP\uff09\u6210\u5458\uff0c\u5c5e\u5e0c\u76df\uff08PH\uff09\u9635\u8425\u3002\u5176\u7236\u4eb2Dato' Seri R. Arunasalam\u662f\u694a\u5dde\u8457\u540d\u5546\u4eba\u548c\u524d\u56fd\u5927\u5370\u5ea6\u4eba\u56e2\u7ed3\u515a\uff08MIC\uff09\u91cd\u8981\u4eba\u7269\u3002\u4ed6\u5728\u4e0a\u8bae\u9662\u79ef\u6781\u63a8\u52a8\u533b\u7597\u6539\u9769\uff0c\u5305\u62ec\u63d0\u9ad8\u533b\u751f\u503c\u73ed\u6d25\u8d34\u3001\u4fee\u8ba2\u5668\u5b98\u6350\u8d60\u6cd5\u5f8b\u3001\u5173\u6ce8\u8840\u6db2\u900f\u6790\u8d39\u7528\u5371\u673a\u7b49\u3002\u540c\u65f6\u62c5\u4efb\u694a\u5dde\u5370\u5ea6\u6559\u5bfa\u4e8b\u4e1a\u59d4\u5458\u4f1a\u526f\u4e3b\u5e2d\uff0c\u79ef\u6781\u7ef4\u62a4\u5370\u5ea6\u793e\u533a\u548c\u5bfa\u5e99\u6743\u76ca\uff0c\u5ef6\u7eed\u7236\u4eb244\u5e74\u7684\u6148\u5584\u4f20\u7edf\u3002",
