  "political_stances": [
    "推动伊斯兰教温和中道(Wasatiyyah)理念,主张'Rahmatan Lil Alamin'(普世慈恩)的宗教治理方针",
    "积极推动跨宗教对话与宗教和谐,担任东南亚宗教和平对话主席",
    "反对种族主义和宗教极端主义,主张建立反歧视法和族裔和解委员会",
    "主张将伊斯兰政党转型为多元种族政党,推动国家诚信党的中间路线",
    "支持反恐与去极端化,曾表态支持中国新疆反极端政策引发争议",
    "主张伊斯兰教应尊重非穆斯林权益,反对将非穆斯林视为二等公民",
    "反对利用宗教和政治法特瓦(fatwa)进行政治操弄,批评伊党哈迪阿旺的政治法特瓦误导民众",
    "推动伊斯兰发展局(JAKIM)改革,引入更具包容性的宗教管理方式"
  ],
  "major_achievements": [
