  "political_stances": [
    {
      "date": "2024-06",
      "topic": "海事法院设立",
      "stance_content": "积极推动釜山设立海事国际商事法院，主张釜山作为海洋首都应同时具备海洋行政和海洋司法功能，将每年约5000亿韩元的诉讼费用留在国内。作为第22届国会1号法案代表发起人推动相关立法。",
      "source": "https://www.yna.co.kr/view/AKR20240614017700051"
    },
    {
      "date": "2026-04",
      "topic": "集体诉讼法",
      "stance_content": "反对执政党主导的集体诉讼法，认为其违反宪法精神，可能导致诉讼泛滥和滥用，主张立法应更加审慎，强调需要防止溯及适用和滥诉。",
      "source": "https://news.tvchosun.com/site/data/html_dir/2026/04/27/2026042790192.html"
    },
    {
      "date": "2024",
      "topic": "司法改革",
      "stance_content": "基于15年检察官经历，主张检察制度合理改革，关注刑事司法和国际法领域制度建设。在法务部任职期间曾主导检察制度改善工作。",
      "source": "https://ko.wikipedia.org/wiki/%EA%B3%BD%EA%B7%9C%ED%83%9D"
    },
    {
      "date": "2024",
      "topic": "釜山地方发展",
      "stance_content": "致力于釜山西区和东区的经济社会发展，推动海洋水产部迁至釜山，主张将釜山打造为完整的海洋首都，强调15年来的海事法院设立夙愿。",
      "source": "https://www.pointe.co.kr/news/articleView.html?idxno=70586"
    }
  ],
