  "political_stances": [
    {
      "date": "2023",
      "topic": "经济自由主义与规制改革",
      "stance_content": "主张英美式经济自由主义，强调减税（法人税、继承税）、废除不必要规制、支持中小企业和初创企业。主张选择性福利而非普惠性福利，认为应通过公平交易委员会维护市场秩序，同时支持中小企业和初创企业的制度性援助以增强竞争力。",
      "source": "나무위키 천하람 문서 - 정치적 견해"
    },
    {
      "date": "2023",
      "topic": "司法改革与严惩主义",
      "stance_content": "主张对儿童性犯罪采取英美法式并科主义和严厉惩处，提出儿童性犯罪防止法案。在n号房事件等儿童性犯罪案件中表现出强硬立场。",
      "source": "나무위키 천하람 문서 - 정치적 견해"
    },
    {
      "date": "2024",
      "topic": "对尹锡悦政府立场",
      "stance_content": "强烈批评尹锡悦政府，称其为「暴力政权、犯罪政权」。12.3内乱事件后称尹锡悦为「禁治产者、疯子」，支持弹劾尹锡悦。主张缩短总统任期并改为四年连任制修宪。评价尹锡悦的政治根基在文在寅政府和进步阵营一侧。",
      "source": "나무위키 천하람 문서 / 韩国媒体报道"
    },
    {
      "date": "2023",
      "topic": "历史观与保守政党反思",
      "stance_content": "以金泳三前总统为政治榜样，主张保守政党应反思全斗焕在5.18民主化运动中的责任。认为维新体制之后的朴正熙不应被自由民主主义的保守政党无条件推崇，强调保守政党应回归自由民主主义和宪法价值的根本。",
      "source": "나무위키 천하람 문서 - 정치적 견해"
    }
  ],
