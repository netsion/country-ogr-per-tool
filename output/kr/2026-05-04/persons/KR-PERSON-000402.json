  "political_stances": [
    {
      "date": "2026",
      "topic": "地域均衡发展与基础设施建设",
      "stance_content": "积极推动忠清北道地区基础设施建设，包括内陆铁路建设、忠北线铁路高速化、报恩至金川铁路等重大SOC项目。主张国家财政应更多投入非首都圈地区，缓解首都圈过度集中问题，促进地方经济自立发展。",
      "source": "https://www.pressian.com/pages/articles/213827"
    },
    {
      "date": "2025",
      "topic": "农业与农村政策",
      "stance_content": "重视农渔民权益保护，主导推动《粮食管理法》修订以确保过剩大米由政府义务收购，推动《农渔业人基础年金支援特别法》等农政法案，主张提高农户收入、稳定农产品价格。",
      "source": "https://www.boeunpeople.com/news/articleView.html?idxno=71563"
    },
    {
      "date": "2026-05",
      "topic": "保守政党改革与公推公正性",
      "stance_content": "作为公推管理委员会委员长，强调领导层不应做出违背国民和党员意志的行为，主张在候选人公推过程中坚持公正透明原则，反对亲缘关系影响公推决策。",
      "source": "https://biz.chosun.com/en/en-policy/2026/05/03/YQFEHCKS6JES5LXCGM6ZDXEEH4/"
    },
    {
      "date": "2025-06",
      "topic": "地方政府行政与公共机构迁移",
      "stance_content": "反对新政府废除海洋水产部釜山迁移计划，认为此举等同于废除行政首都，坚持推进国家均衡发展和地方分权。",
      "source": "https://v.daum.net/v/20250626200001260"
    }
  ],
