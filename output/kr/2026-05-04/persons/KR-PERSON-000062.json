  "political_stances": [
    {
      "date": "2024",
      "topic": "减税与营商环境",
      "stance_content": "主张积极降低继承税、赠与税和法人税，认为韩国应顺应全球减税趋势先发制人。强调通过税制改革打造企业友好环境，防止'韩国出走'（Korea Exodus），认为高税负导致企业外迁和竞争力下降。"
    },
    {
      "date": "2024-07",
      "topic": "小工商人与民生经济",
      "stance_content": "长期关注小工商人和自营业者困境，担任民生经济安定特别委员会委员长期间主办多次政策讨论会。主张扩大小工商人政策金融支援，强调在紧缩财政基调下仍需集中支援低生育老龄化和弱势小工商人。"
    },
    {
      "date": "2024-08",
      "topic": "朝野协商与国会运作",
      "stance_content": "担任政策委员会议长期间强调'民生优先'，主张从非争议法案入手推动朝野协商处理，改善国会僵局。主张应优先处理年金改革、半导体特别法等跨党民生议题。"
    },
    {
      "date": "2024",
      "topic": "金融投资税与资本市场",
      "stance_content": "反对金融投资所得税（金投税）的实施，认为该税制会加剧资本市场不稳定。关注虚拟资产交易所股份限制的违宪风险问题，主张保护财产权和经营自由。"
    }
  ],
