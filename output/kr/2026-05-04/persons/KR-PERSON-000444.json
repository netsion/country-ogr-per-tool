  "political_stances": [
    {
      "date": "2022-06",
      "topic": "核电产业与放射性废弃物管理",
      "stance_content": "积极主张扩大核电利用，推动将釜山打造为核电产业中心。认为高位阶放射性废弃物处置是核电可持续运营的前提条件，主张国家应尽快立法确保处置设施建设，并通过向核电选址内储存废弃物征税等方式补偿当地居民。反对在已停运核电选址内永久存放放射性废弃物。",
      "source": "媒体新闻报道 (https://www.mediainnews.com/news/articleView.html?idxno=23777)"
    },
    {
      "date": "2024-03",
      "topic": "地方交通基础设施建设",
      "stance_content": "将'四通八达新交通时代机张'列为5大选区公约之首，推动城市铁道正线和机张线建设、KTX-伊音机张郡内停靠、东海线三圣站新建、机张半松隧道及吴西亚延长线（2号线）早期建设、釜山~梁山~蔚山广域铁道建设等全方位交通基础设施扩容。",
      "source": "釜山日报 (https://www.busan.com/view/busan/view.php?code=2024032710135966175)"
    },
    {
      "date": "2025-04",
      "topic": "核电产业生态系统与全球市场战略",
      "stance_content": "在采访中主张构建'无忧核电生态系统'，推动韩国主导全球核能市场。强调高位阶放射性废弃物特别法的通过将为核电产业的可持续发展奠定基础，并积极推进釜山·梁山·蔚山广域铁道建设以产生协同效应。",
      "source": "新闻今日 (https://www.news2day.co.kr/article/20250407500173)"
    }
  ],
