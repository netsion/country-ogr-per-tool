  "political_stances": [
    {
      "date": "2021-06",
      "topic": "游戏产业监管改革",
      "stance_content": "主张废除针对青少年的强制游戏关机制度（shutdown制度），认为该制度侵犯青少年权利且缺乏实效性，并于2021年成功主导推动废除法案在国会全体会议通过。同时积极推动游戏产业法改革，加强打击非法外挂程序和规范概率型道具信息公示。",
      "source": "https://ko.wikipedia.org/wiki/%EC%A0%84%EC%9A%A9%EA%B8%B0"
    },
    {
      "date": "2022-11",
      "topic": "反日独立外交与历史认知",
      "stance_content": "在对日关系上持强硬立场，曾于2022年在国会预算决算委员会质询中批评日本海上自卫队观舰式上升旭日旗敬礼行为并现场撕毁旭日旗进行抗议。2023年4月访问独岛表明对领土主权问题的强硬立场。在任期间还揭露了日本端岛（军舰岛）世界文化遗产申报中的历史歪曲问题以及货币博物馆建筑中伊藤博文亲笔题字等问题。",
      "source": "https://namu.wiki/w/%EC%A0%84%EC%9A%A9%EA%B8%B0(%EC%A0%95%EC%B9%98%EC%9D%B8)"
    },
    {
      "date": "2021-11",
      "topic": "军事与兵役制度改革",
      "stance_content": "积极推动改善服役军人待遇，发起了'士兵休假周末保障法'（将士兵休假日数与干部统一适用）、'预备军训练受训者不利待遇防止法'等多部军事相关法案。批评公共机构晋升中反映军经历的制度，主张应将军经历反映义务化以消除不公平现象。",
      "source": "https://sensepeople.tistory.com/entry/%EC%A0%95%EC%B9%98%EC%9D%B8-%EC%A0%84%EC%9A%A9%EA%B8%B0-%ED%94%84%EB%A1%9C%ED%95%84-%EC%A0%95%EB%B3%B4"
    },
    {
      "date": "2024-04",
      "topic": "青年政策与低生育率应对",
      "stance_content": "作为韩国最年轻的国会议员之一，持续关注青年就业、住房和低生育率问题。主张低生育率委员会应以备婚夫妇、新婚夫妇和育儿夫妇100%组成，确保政策制定能反映实际育儿群体的需求。积极推动青年从政，认为青年政治对于未来韩国社会至关重要。",
      "source": "https://www.chosun.com/politics/assembly/2024/04/24/ZSMGMHWSN5DPNLL26KV4ITD4KQ/"
    },
    {
      "date": "2025-12",
      "topic": "检察改革与民主法治",
      "stance_content": "积极参与司法改革和检察改革议题，担任共同民主党司法改革特别委员会副委员长，参与'尹锡悦政权政治检察捏造起诉疑案真相查明国政调查特别委员会'，主张加强对检察权力的监督与制约。此外还发起了禁止公务员反宪法行为的公务员法修正案。",
      "source": "https://www.assembly.go.kr/members/22nd/JEONYONGGI"
    }
  ],
