  "political_stances": [
    {
      "date": "2024-12-03",
      "topic": "戒严与弹劾",
      "stance_content": "2024年12月3日尹锡悦宣布紧急戒严后，积极参与戒严解除投票。戒严军逼近国会时拍桌高呼'戒严军正在进入'，推动迅速表决解除戒严。随后担任尹锡悦弹劾追诉团委员，主张'内乱必须彻底追究'。",
      "source": "https://namu.wiki/w/%EA%B9%80%EA%B8%B0%ED%91%9C"
    },
    {
      "date": "2025-03",
      "topic": "尹锡悦弹劾",
      "stance_content": "在KBS广播访谈中表示'弹劾是无法写驳回决定书的事态'，认为弹劾判决是必然结果，主张内乱终结后民主阵营应当整合。",
      "source": "https://news.kbs.co.kr/news/view.do?ncd=8204341"
    },
    {
      "date": "2025-10",
      "topic": "司法改革——裁判诉愿制",
      "stance_content": "作为国会法制司法委员会委员，代表发议宪法裁判所法修正案，推动引入'裁判诉愿制'（允许对法院确定判决提起宪法诉愿），主张'司法裁判侵害国民基本权时应提供永恒的救济途径'。",
      "source": "https://valuable12.com/entry/%EA%B9%80%EA%B8%B0%ED%91%9C-%EA%B5%AD%ED%9A%8C%EC%9D%98%EC%9B%90-%ED%94%84%EB%A1%9C%ED%95%84-%ED%95%99%EB%A0%A5-%EB%82%98%EC%9D%B4-%EA%B3%A0%ED%96%A5-%EC%A3%BC%EC%9A%94-%EC%9D%B4%EB%A0%A5"
