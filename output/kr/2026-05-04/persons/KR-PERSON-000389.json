  "political_stances": [
    {
      "date": "2024",
      "topic": "文化产业振兴",
      "stance_content": "积极推动文化产业立法，主导制定音乐剧产业振兴法、韩流产业振兴基本法、广告产业振兴法等多项文化相关法案，主张将韩国文化产业制度化为国家战略性产业，推动K-文化全球化。",
      "source": "国会立法记录 / 新闻报道"
    },
    {
      "date": "2024",
      "topic": "地方消亡应对与均衡发展",
      "stance_content": "关注人口危机和地方消亡问题，担任国民力量党人口危机特别委员会委员，主张通过政策手段应对地方人口流失，推动区域均衡发展。在第22届国会中担任地区均衡发展论坛研究委员。",
      "source": "国会活动记录 / 维基百科"
    },
    {
      "date": "2021",
      "topic": "游戏产业规制",
      "stance_content": "对概率型道具规制作持审慎态度，承认概率型道具的赌博性和对青少年的危害，但认为过度监管可能阻碍产业发展，主张在消费者保护和产业成长之间寻求平衡，应与外国游戏企业实施同等水平的监管。",
      "source": "国会文化体育观光委员会会议记录"
    },
    {
      "date": "2024",
      "topic": "AI与数字内容产业",
      "stance_content": "担任国民力量党AI三大强国跃进特别委员会内容领域小委员长，主张韩国应在AI时代成为全球三大AI强国之一，重点推动AI与内容产业融合发展。",
      "source": "国民力量党委员会任命 / 新闻报道"
    },
    {
      "date": "2024",
      "topic": "消费者权益保护",
      "stance_content": "重视消费者权益保护，因相关立法贡献获2024年\"消费者权益大奖\"立法部门奖。推动旅游行业中小旅行社保护方案，关注文化领域消费者权益问题。",
      "source": "2024 Consumer Watch颁奖报道"
    }
