  "political_stances": [
    {
      "date": "2024-04",
      "topic": "金融投资所得税（금투세）",
      "stance_content": "主张按计划实施金融投资所得税，反对未经试行即废除。认为对股票收益征税是实现税收公平的必要手段，批评民主党过于关注富裕阶层利益而忽视平民和中产阶层诉求。",
      "source": "https://www.businesspost.co.kr/BP?command=article_view&num=350267"
    },
    {
      "date": "2025-11",
      "topic": "房地产持有税与调控政策",
      "stance_content": "主张强化房地产持有税（综合房地产税），认为应通过增加持有税促使多住宅持有者释放库存住房，从而抑制房价上涨。批评党内因担心选票而不敢推动房产税改革的做法。",
      "source": "https://www.khan.co.kr/article/202511100600101"
    },
    {
      "date": "2024",
      "topic": "民主化与人权",
      "stance_content": "大学期间即投身学生民主化运动，服役期间因提出军中人权问题遭军事法庭判刑。政治生涯中持续关注人权议题，曾任韩国残疾人权论坛理事。",
      "source": "https://ko.wikipedia.org/wiki/%EC%A7%84%EC%84%B1%EC%A4%80"
    },
    {
      "date": "2026-03",
      "topic": "财政预算与经济政策",
      "stance_content": "作为预算决算特别委员会委员长和共同民主党政策委员会议长，主张扩张性财政政策以刺激经济，强调对大企业和富裕阶层增税、对中低收入阶层提供更多财政支持。",
      "source": "https://en.infomaxai.com/news/articleView.html?idxno=109578"
    }
