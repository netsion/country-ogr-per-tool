  "political_stances": [
    {
      "date": "2024-12",
      "topic": "弹劾与宪政秩序",
      "stance_content": "2024年12月在尹锡悦总统弹劾案中投下赞成票，成为岭南（TK）地区首位表态支持弹劾的执政党议员，主张'最重要的标准是国民'，认为紧急戒严是错误的，应通过弹劾程序恢复宪政秩序。",
      "source": "https://www.gonews.kr/%EA%B6%8C%EC%98%81%EC%A7%84-%ED%94%84%EB%A1%9C%ED%94%84/"
    },
    {
      "date": "2024-06",
      "topic": "国土交通与城市开发",
      "stance_content": "作为国会国土交通委员会干事，长期关注城市开发与交通基础设施政策。在大邱市长任内推动西大邱站开通运营（2022年），主张通过基础设施建设带动区域经济发展，提出大邱市政厅新办公大楼搬迁等城市发展方案。",
      "source": "https://www.assembly.go.kr/portal/assm/assmMemb/memberProfile.do?monaCd=LYY5513O"
    },
    {
      "date": "2025-01",
      "topic": "航空安全与灾难应对",
      "stance_content": "担任济州航空客机事故（12·29惨案）特别委员会委员长，主导事故真相调查和受害者救济立法，推动'12·29客机惨案受害者救济及支援特别法'通过，主张加强航空安全监管和灾难应对体系。",
      "source": "https://www.inews24.com/view/1802054"
    },
    {
      "date": "1990",
      "topic": "朝韩关系与统一政策",
      "stance_content": "早年任统一院统一政策辅佐官，博士论文研究朝鲜核问题的韩国政策决策过程，主张以国家安全为前提的务实对朝政策。国会内参与'朝鲜与统一'议员论坛活动。",
      "source": "https://ko.wikipedia.org/wiki/%EA%B6%8C%EC%98%81%EC%A7%84_(%EC%A0%95%EC%B9%98%EC%9D%B8)"
    },
    {
      "date": "2021-05",
      "topic": "新冠疫情疫苗",
      "stance_content": "推动大邱市独立采购3000万剂辉瑞新冠疫苗，但后被证实为诈骗提案而公开道歉。",
      "source": "维基百科 / 新闻报道"
    }
  ],
