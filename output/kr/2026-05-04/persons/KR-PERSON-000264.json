  "political_stances": [
    {
      "date": "2024-09",
      "topic": "科技产业政策",
      "stance_content": "主张科学技术是韩国未来的核心，应积极推动科技创新和数字经济发展，完善相关制度框架，为未来产业奠定制度化基础。",
      "source": "https://blog.naver.com/minkyucool/223588390838"
    },
    {
      "date": "2025-12",
      "topic": "股价打压防止法",
      "stance_content": "为防止财阀家族为减少继承税而故意压低股价的行为，主导发起相续税法修正案（股价打压防止法），主张加强资本市场公平性和透明度。",
      "source": "https://www.instagram.com/p/DSjpZ1eCWLl/"
    },
    {
      "date": "2026-01",
      "topic": "房产与养老改革",
      "stance_content": "发起所得税法修正案（被称为'卖掉首尔房子养老金6亿法'），主张出售首尔房产时可享受更大额度的年金账户税收优惠，缓解退休养老压力。",
      "source": "https://www.businesspost.co.kr/BP?command=article_view&num=427276"
    },
    {
      "date": "2026-04",
      "topic": "国有资产管理",
      "stance_content": "发起国有财产法修正案（国有资产贱卖防止法），主张300亿韩元以上国有资产和公共机构资产出售须向国会相关常任委员会事前报告，加强国会监督和透明度。",
      "source": "https://www.newspim.com/news/view/20260428000082"
    },
    {
      "date": "2024-04",
      "topic": "市场经济理念",
      "stance_content": "倡导'温暖的市场经济'理念，继承金槿泰的政治哲学，主张在市场经济体制中不应忽视失败者和被排斥者，应通过政策帮助他们重新获得竞争力。",
      "source": "https://www.mk.co.kr/en/politics/11036840"
    },
    {
      "date": "2024-03",
      "topic": "国会改革",
      "stance_content": "主张修改国会法，对损害国会权威的国会议员施加一定惩罚甚至召回机制，提高国会在国民中的信任度，实现'做事的国会'。",
      "source": "https://m.blog.naver.com/kdnews21/223374988209"
    }
  ],
