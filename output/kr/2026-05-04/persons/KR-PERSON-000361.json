  "political_stances": [
    {
      "date": "2024-09",
      "topic": "国防产业发展与K-防产共生生态",
      "stance_content": "积极推动韩国国防产业发展，主张国防产业不仅是安全保障领域，更是国家核心成长产业。代表发起《韩国国防产业振兴院法》法案，推动设立专门的国防产业振兴机构。主张建立大企业与中小企业的共生体系，确保体系企业的成果惠及整个供应链的协作企业。",
      "source": "https://www.fnnews.com/news/202604290819119430"
    },
    {
      "date": "2026-04",
      "topic": "国防产业出口型R&D基金",
      "stance_content": "提出设立'出口型国防R&D基金'，主张打破当前以军队需求为基础的R&D模式对出口型定制技术的排斥。认为产业部R&D也应以个别企业为单位支援，不利于中长期出口技术研发，呼吁建立面向出口的独立R&D支持体系。",
      "source": "http://www.knpnews.com/news/articleView.html?idxno=33611"
    },
    {
      "date": "2024-07",
      "topic": "昌原国防产业集群发展",
      "stance_content": "主张将昌原的国防产业培育为国家核心国防产业基地，推动国防产业出口。提出国防产业振兴专门机构的立法依据，致力于将昌原打造为国防产业出口的牵引基地。",
      "source": "https://www.fnnews.com/news/202407110829414574"
    },
    {
      "date": "2018",
      "topic": "城市再生与地方分权",
      "stance_content": "任昌原市长期间大力推进'昌原型城市再生'模式，提出'城市竞争力即国家竞争力'的理念。推动昌原特别市的设立，主张通过地方分权强化自治权力。主张将昌原发展为智慧城市、马山发展为文化城市、镇海发展为东北亚物流中心海洋城市的差异化发展战略。",
      "source": "https://www.ohmynews.com/NWS_Web/View/at_pg.aspx?CNTN_CD=A0002734292"
    }
  ],
