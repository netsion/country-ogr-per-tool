  "political_stances": [
    {
      "date": "2025-01",
      "topic": "数字基础设施安全与网络稳定化",
      "stance_content": "主导提出《网络稳定化法》（네트워크 안정화법），要求YouTube、Facebook等大型平台在变更流量路由时提前通知并保障服务稳定性。后续又提出CDN事业者稳定性监管立法，防止\"第二次Cloudflare事故\"。强调数字基础设施安全是国民基本权利。",
      "source": "国会立法信息 / Facebook公告"
    },
    {
      "date": "2025-01",
      "topic": "YouTube算法监管与防止信息操控",
      "stance_content": "提出被称为\"尹锡悦防止法\"的法案，针对YouTube算法推荐服务导致的过滤气泡（filter bubble）问题，要求加强平台内容推荐的透明度和用户选择权，没收利用煽动性内容获利的\"不健全YouTuber\"的经济利益。主张防止算法推荐被用于政治煽动和传播虚假信息。",
      "source": "KBC光州放送报道 / 国会立法信息"
    },
    {
      "date": "2026-04",
      "topic": "地方自主R&D创新与区域均衡发展",
      "stance_content": "主导提出并推动通过《地域主导R&D革新法》，打破首都圈集中的国家R&D结构，使地方成为科技创新的主体。该法案被李在明政府列为国政核心课题。同时提出\"5极3特\"战略，主张将中央政府审批权和规制解除权限向地方政府转移。",
      "source": "亚洲经济报道 / 国会本会议通过记录"
    },
    {
      "date": "2026-04",
      "topic": "人口减少地区住房振兴与地方消失防止",
      "stance_content": "提出《租税特例限制法》修正案，将人口减少地区住房取得时享受的转让税、综合不动产税特例期限延长5年，鼓励城市居民购买\"第二住宅\"，通过人口流入防止地方城市消失。同时提出《人口减少地区住房活性化法》，从制度层面支持地方社区振兴。",
      "source": "亚洲经济 / 木浦时报报道"
    },
    {
      "date": "2025",
      "topic": "AI技术治理与未来立法",
      "stance_content": "积极关注人工智能发展，在国会科学技術情报广播通信委员会中主导AI相关议题。以\"热爱AI的公职人员出身议员\"著称，提出AI时代的立法框架应先行于技术发展，主张建立议会层面的AI治理能力。在国际议会联盟（IPU）第3常任委员会上以韩国国会先进立法案例发表演讲。",
      "source": "国会放送 / Facebook公告"
    }
  ],
