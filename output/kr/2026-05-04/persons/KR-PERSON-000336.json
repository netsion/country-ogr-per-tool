    {
      "date": "2020-06-30",
      "topic": "青年政治参与",
      "stance_content": "主张降低青年政治参与门槛，推动「青年政治阶梯三法」（政党法、政治资金法、公职选举法修订案），要求青年公费选举名额30%、青年最高委员制度化、设立青年副代表等。",
      "source": "namu.wiki"
    },
    {
      "date": "2020-10",
      "topic": "青年住房保障",
      "stance_content": "提出《青年住房稳定特别法》（又称「全身投入防止法」），主张公共租赁住宅70%优先供应青年、国民住宅出售50%特别供应青年，并给予青年优惠贷款利率和住房基金条件。",
      "source": "namu.wiki"
    },
    {
      "date": "2020-09",
      "topic": "青年政策机构",
      "stance_content": "主张设立部长级「青年处」（청년처），认为青年问题涵盖就业、住房、债务、创业、保育、教育等各方面，需要专门中央机构统筹。",
      "source": "namu.wiki"
    },
    {
      "date": "2021-07",
      "topic": "性平权",
      "stance_content": "反对保守阵营提出的「女性家族部废除」主张，批评其忽视性别平等价值、煽动性别矛盾，强调女性家族部的设立正是源于父权社会对女性人权的忽视。",
      "source": "namu.wiki"
    },
    {
      "date": "2024-12",
      "topic": "民主防卫与司法改革",
      "stance_content": "在2024年12月3日戒严事件中翻墙进入国会参与戒严解除投票；主张扩大大法官人数以推进司法改革；批评检方对尹锡悦总统的不当释放决定。",
      "source": "namu.wiki"
    }
