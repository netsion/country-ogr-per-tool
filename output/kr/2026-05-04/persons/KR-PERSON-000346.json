  "political_stances": [
    {
      "date": "2025",
      "topic": "RE100可再生能源政策",
      "stance_content": "积极推动RE100可再生能源自力园区建设，主导制定《可再生能源自立园区组建及支援特别法》（RE100特别法），主张通过能源高速道路和可再生能源产业园区推动绿色转型与地区经济发展。作为执政党唯一参与2025年国立立法博览会的议员，亲自推广该法案。",
      "source": "南道新闻 / https://www.namdonews.com/news/articleView.html?idxno=834045"
    },
    {
      "date": "2024-04",
      "topic": "国会改革与国民召回制",
      "stance_content": "主张引入国会议员国民召回制度，提出像弹劾总统一样国会议员若不称职也应被召回，致力于国会议员特权削减与政治改革，强调通过制度改革恢复国民对政治的信任。代表发起了《关于国会议员国民召回的法律案》和《国会法部分修正法律案》。",
      "source": "韩国日报 / https://www.kmib.co.kr/article/view.asp?arcid=0020027665"
    },
    {
      "date": "2026",
      "topic": "地区均衡发展",
      "stance_content": "致力于推动光州与全南行政整合，积极为光州南区争取国费预算，2026年度为光州争取到3.9497万亿韩元国费预算，其中AI相关预算1597亿韩元，南区相关预算475亿韩元为政府原案未反映部分额外争取。",
      "source": "iminju.net / https://www.iminju.net/news/articleView.html?idxno=158831"
    },
    {
      "date": "2025-12",
      "topic": "中小风险企业政策",
      "stance_content": "作为产业通商资源中小风险企业委员会委员，积极推动中小企业相关立法，但因其代表发起的中小企业中央会会长连任限制废除法案引发争议，被批评为量身定制立法。同时推动城市天然气事业法修正等民生相关立法。",
      "source": "京乡新闻 / https://www.khan.co.kr/article/202601230601001"
    }
  ],
