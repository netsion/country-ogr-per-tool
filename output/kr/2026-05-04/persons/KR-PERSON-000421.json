  "political_stances": [
    {
      "date": "2024-07",
      "topic": "国民年金改革 - 结构改革优先",
      "stance_content": "主张国民年金改革不仅限于参数改革（保险费率、所得替代率等数字调整），必须同时推进结构改革，包括基础生活保障制度、退休年金、住宅年金等制度的整合。强调'即便需要10年、20年，也要制定能维持100年的年金改革方案'，并主张尽早设立国会常设年金特别委员会以推动社会共识。",
      "source": "每日经济新闻 (https://www.edaily.co.kr/news/read?newsId=01259526638925984)"
    },
    {
      "date": "2025-02",
      "topic": "国民年金保险费率上调",
      "stance_content": "在国会政府质询中明确主张'国民年金保险费率上调至13%的方案应尽早通过，无论是常任委员会还是特别委员会，明天就该通过'。认为参数改革应先行处理，保险费率上调是不可避免的国民痛苦分担。",
      "source": "Daum新闻 (https://v.daum.net/v/20250213111906574)"
    },
    {
      "date": "2026-02",
      "topic": "国民年金基金运营独立性强化",
      "stance_content": "主导发起国民年金法部分修正案，要求保障国民年金基金管理与运营的独立性，明确保健福祉部长官在基金运营独立性方面的责任，防止政治性干预基金运营。",
      "source": "KNS新闻 (https://www.kns.tv/news/articleView.html?idxno=986914)"
    },
    {
      "date": "2024-12",
      "topic": "尹锡悦总统弹劾案 - 赞成",
      "stance_content": "在2024年12月14日尹锡悦总统弹劾表决中表态赞成弹劾。此前12月3日戒严令发布后，参与了国民力量党内部'政治安定化任务force'，讨论有序退位方案。",
      "source": "Daum新闻 (https://v.daum.net/v/20241216050124070)"
