  "political_stances": [
    {
      "date": "2024-10",
      "topic": "农业与农村振兴政策",
      "stance_content": "高度关注农业危机，主张扩大对青年农户的政府支援。针对国内青年农户从2020年的12,426户锐减至2024年的4,601户（4年内减少62.9%）的严峻现实，代表发起《后继青年农渔业人法》和《韩国4-H法》，推动建立泛政府层面的青年农户支援体系。同时发起农渔业税制支援延长12法打包法案，主张将相关税制支援特例从2026年底延长至2030年。",
      "source": "Daum新闻 (https://v.daum.net/v/20260316150307309)"
    },
    {
      "date": "2025-04",
      "topic": "灾难应对与山火防灾",
      "stance_content": "担任国民力量党山火灾难应对特别委员会委员长及国会山火灾害支援对策特别委员会委员，强调强化灾难应对体系。代表发起'庆北·庆南·蔚南山火灾害救济特别法'，主张扩大受灾居民的居住、生计、农林水产、小商工支援范围，建立更完善的灾难应对机制。",
      "source": "WebPlus新闻 (http://www.webplusnews.kr/news/articleView.html?idxno=37587)"
    },
    {
      "date": "2024-02",
      "topic": "地区发展与人口减少应对",
      "stance_content": "以'永川大转换·清道大飞跃'为口号，将应对地区消失危机作为核心课题。主要承诺包括：大邱地铁1号线延伸至永川、韩国马事会本社迁至永川、永川赛马公园第2阶段事业推进、大邱军部队永川迁移引进、清道各北隧道建设等交通基础设施扩充。主张通过不间断的地区发展克服地区消失危机。",
      "source": "庆北日报 (https://www.kyongbuk.co.kr/news/articleView.html?idxno=4000349)"
    },
    {
      "date": "2025-03",
      "topic": "APEC峰会支援",
      "stance_content": "担任2025年APEC峰会支援特别委员会干事，积极推动APEC庆州峰会的筹备支援工作，关注峰会对庆北地区经济带动效应。",
      "source": "大韩民国国会 (https://assembly.go.kr/members/22nd/LEEMANHEE)"
    }
