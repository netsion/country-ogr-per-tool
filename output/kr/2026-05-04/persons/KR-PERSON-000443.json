  "political_stances": [
    {
      "date": "2024-06",
      "topic": "国防安全",
      "stance_content": "主张强化韩国自主国防能力，积极推动反恐立法与国防改革。代表发起了《电波法》修订案，扩大电波干扰设备的使用范围以应对无人机恐怖威胁，该法案于2026年3月获国会全体会议通过。持续关注军人人事制度改善和军人福利提升。",
      "source": "国会立法记录及新闻报道"
    },
    {
      "date": "2024-06",
      "topic": "人口减少地区振兴",
      "stance_content": "高度关注农村和人口减少地区的生存危机，代表发起了多项相关法案：包括《公职选举法》修订案以保护人口消失地区的选举区、《国家财政法》修订案以降低人口减少地区社会基础设施项目的预备妥当性调查标准、《中小企业人力确保法》修订案将青年劳动者年龄上限从34岁扩大到39岁等。",
      "source": "大邱日报、庆北日报等报道"
    },
    {
      "date": "2026-01",
      "topic": "消防安全",
      "stance_content": "推动AI火灾早期感知系统立法，代表发起《火灾预防及安全管理法》修订案，引入人工智能技术用于火灾早期监测。还发起风力发电机等高处作业平台消防安全法规修订，填补监管空白。",
      "source": "荣州市民新闻报道"
    },
    {
      "date": "2024-06",
      "topic": "外交安保",
      "stance_content": "作为国防委员会委员及前国家安保室第二次长，对朝鲜核设施分类问题、驻韩美军防卫费分担等议题持强硬立场，强调韩美同盟重要性。曾参与乌克兰安全问题圆桌会议，关注国际安全局势变化。",
      "source": "朝鲜日报英文版、国会政策资料"
    }
  ],
