  "political_stances": [
    {
      "date": "2025-04",
      "topic": "核能与能源政策",
      "stance_content": "积极主张扩大核电发展，推动可再生能源与核电平衡扩展的能源组合战略。主张实现碳中和离不开核电，要求立即重启新韩蔚3·4号机组建设。主导推动蔚珍核电氢能国家产业园区建设，提出氢能特化园区与核电电力联动的具体方案，发起《电气事业法》修正案推动核电电力向氢能园区直接供应。",
      "source": "国会发言、能源论坛、法案发起记录"
    },
    {
      "date": "2025-11",
      "topic": "财政预算与政府支出",
      "stance_content": "作为国会预算结算特别委员会干事，主张财政纪律与审慎预算管理。在2026年度预算审议中代表国民力量党参与预算协商，关注合理控制政府支出规模。",
      "source": "国会预算审议记录、媒体报道"
    },
    {
      "date": "2024-12",
      "topic": "反对弹劾尹锡悦",
      "stance_content": "在尹锡悦总统弹劾案中坚持反对立场，反对宪法裁判官3人任命，认为在弹劾审判未结状态下任命缺乏宪法依据。参与国民力量党弹劾反对党论投票。",
      "source": "国会投票记录、媒体报道"
    },
    {
      "date": "2025-12",
      "topic": "地方发展与大邱庆北新机场",
      "stance_content": "全力推动大邱庆北（TK）新机场义城货物航站楼建设，经过约100余次与政府各部门协商，最终成功使义城专用货物航站楼纳入民间机场基本计划，确保庆北道航空物流产业基础。",
      "source": "国会活动记录、媒体报道"
    }
  ],
