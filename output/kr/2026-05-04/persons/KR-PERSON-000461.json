  "political_stances": [
    {
      "date": "2024-06",
      "topic": "情緒行動危机学生支援",
      "stance_content": "主张制定《情緒行動危机学生支援法》，在学校配置情緒行動支援专业教师，由国家统筹制定五年综合计划，系统性支援ADHD、品行障碍、反抗障碍等情緒行動危机学生，同时减轻教师负担。",
      "source": "教育媒体[创] (https://www.edupress.kr/news/articleView.html?idxno=11779)"
    },
    {
      "date": "2024-05",
      "topic": "AI数字教科书",
      "stance_content": "反对无条件推进AI数字教科书引入，指出过度使用数字设备导致思考力和集中力下降，主张应慎重考虑数字设备的逆功能，参考芬兰等国限制校内数字设备使用的做法。",
      "source": "OhMyNews (https://www.ohmynews.com/NWS_Web/View/at_pg.aspx?CNTN_CD=A0003034529)"
    },
    {
      "date": "2024-05",
      "topic": "学生权利条例与教育改革",
      "stance_content": "反对各地学生人权条例被废止，批评这是'教育的后退和民主主义的后退'，主张制定学生人权法加强法律制度保障，认为根本解决需要从竞争式教育体制中脱胎换骨。",
      "source": "OhMyNews (https://www.ohmynews.com/NWS_Web/View/at_pg.aspx?CNTN_CD=A0003034529)"
    },
    {
      "date": "2024-05",
      "topic": "社会差距与包容性教育",
      "stance_content": "秉持'抑强扶弱'精神，认为缩小社会差距、提高社会流动性指数是自己必须完成的使命，主张让家庭困难的儿童、多文化家庭儿童、残疾儿童都能获得平等机会。",
      "source": "OhMyNews (https://www.ohmynews.com/NWS_Web/View/at_pg.aspx?CNTN_CD=A0003034529)"
    },
    {
      "date": "2025-09",
      "topic": "AI教育与特殊教育",
      "stance_content": "主张AI时代也要实现'教育民主化'，消除AI文盲，利用AI技术为特殊教育提供个性化教育方案，推进包容性教育。",
      "source": "The AI (http://www.newstheai.com/news/articleView.html?idxno=9092)"
    }
  ],
