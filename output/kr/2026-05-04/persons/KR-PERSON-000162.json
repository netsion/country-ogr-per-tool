  "political_stances": [
    {
      "date": "2015",
      "topic": "朝鲜人权与核问题",
      "stance_content": "作为国会外交统一委员长，坚决反对朝鲜核开发，推动通过朝鲜第四轮核试验谴责决议。在联合国朝鲜人权事务所开设仪式上出席，持续推动朝鲜人权法立法。对朝采取强硬立场，同时主张通过两轨外交推动统一。",
      "source": "韩语维基百科"
    },
    {
      "date": "2019-02",
      "topic": "朝鲜核威慑与自主国防",
      "stance_content": "2019年2月警告称，如果美国无法让朝鲜实现无核化，首尔可能会考虑要求拥有自己的核武器以应对北方威胁。",
      "source": "英文维基百科"
    },
    {
      "date": "2015",
      "topic": "韩中自由贸易协定（FTA）",
      "stance_content": "作为外交统一委员长积极推进韩中FTA批准同意案的处理，在2015年11月30日召开外通委全体会议通过FTA批准同意案，从正式签署到国会通过仅用6个月。",
      "source": "韩语维基百科"
    },
    {
      "date": "2022-10",
      "topic": "气候变化与低生育率应对",
      "stance_content": "担任气候环境大使期间代表韩国出席COP27，推动气候外交。同时担任低生育高龄社会委员会副委员长，关注人口结构变化对国家未来的影响。2023年8月创立'人口与气候及未来'法人团体并任理事长。",
      "source": "韩国国会官网/维基百科"
    }
  ],
