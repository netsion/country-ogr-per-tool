  "major_achievements": [
    {
      "date": "2024-04-10",
      "organization": "国会（국회）",
      "achievement": "当选第22届国会议员。2024年4月10日在第22届国会议员选举中，以52.94%的得票率（44,623票）当选首尔江北区乙选区国会议员。该选区在选举过程中经历两次候选人更替后，韩玟洙被战略公推并成功当选。"
    },
    {
      "date": "2024-06-21",
      "organization": "国会（국회）",
      "achievement": "发起《城市及居住环境整备法》修正案（原住民再定居法）。就任后首个法案，旨在提高再开发与再建筑过程中原住民的再定居率，要求在基本计划和整备计划中反映居民再定居对策，并为实施再定居计划的开发者提供容积率上浮至125%的特例。"
    },
    {
      "date": "2024-08-22",
      "organization": "国会（국회）",
      "achievement": "代表发起《人工智能基本法》。作为国会科学技术情报放送通信委员会委员，为韩国AI产业建立法律基础框架，规范一定规模以上的AI事业者遵守基本准则。"
    },
    {
      "date": "2025-03-20",
      "organization": "国会（국회）",
      "achievement": "代表发起大型科技平台应用商店收费规制法案。《电气通信事业法》修正案要求谷歌、苹果等大型科技平台允许外部支付方式并禁止不合理的收费行为，加强消费者权益保护。"
    },
    {
      "date": "2024-11",
      "organization": "国会（국회）",
      "achievement": "发起不合法垃圾短信根绝法案。《电气通信事业法》修正案加强对大量文字传输业者的事后管理，扩大调查权限范围，旨在根绝不合法垃圾短信。"
    }
