  "political_stances": [
    {
      "date": "2024-08",
      "topic": "人工智能立法与产业发展",
      "stance_content": "积极推动人工智能基本法制建设，主张为AI产业建立法律基础框架，促进AI数据中心建设，强调韩国AI服务应从起步阶段就面向全球化发展。代表发起了《人工智能基本法》和《人工智能数据中心振兴特别法》。",
      "source": "国会法案记录"
    },
    {
      "date": "2025-03",
      "topic": "科技平台监管与消费者权益",
      "stance_content": "主张加强对谷歌、苹果等大型科技平台的应用商店收费行为的监管，代表发起《电气通信事业法》修正案，要求应用商店经营者允许外部支付方式并提供外部链接，禁止不合理的收费行为。",
      "source": "国会法案记录"
    },
    {
      "date": "2024-06",
      "topic": "城市更新与居民权益",
      "stance_content": "关注再开发与再建筑过程中原住民的居住权益，主张提高原住民再定居率，反对将再开发视为驱逐居民的项目，强调应通过容积率奖励等机制鼓励为原住民制定再定居方案。",
      "source": "国会法案记录"
    },
    {
      "date": "2025-01",
      "topic": "舆论调查机构监管",
      "stance_content": "主张加强对舆论调查机构的登记管理与定期检查义务，提高调查机构的透明度与可信度，维护选举公正性。",
      "source": "国会法案记录"
    }
  ],
