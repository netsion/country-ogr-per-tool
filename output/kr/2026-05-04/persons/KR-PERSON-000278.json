  "political_stances": [
    {
      "date": "2024-07",
      "topic": "公共医科大学设立",
      "stance_content": "积极推动公共医科大学（공공의대）设立法案，主张通过国家责任培养公共医疗人才解决地方医疗空白问题。代表发起了《国立医学专门研究生院设立及运营相关法律》（国立医大院法），该法已于2026年4月通过国会全体会议。规定15年义务服务和每年100名招生规模。",
      "source": "国会保健福祉委员会法案审议"
    },
    {
      "date": "2025-09",
      "topic": "内乱特别法庭设立",
      "stance_content": "2025年9月公开反对党领导层推进的内乱特别法庭设立方案，认为在未修宪的情况下由国会讨论通过相关法案违反宪法第101条关于司法权归属法院的规定，将宪法法院和法院分开设计的制度与设立特别法庭不符。此举遭到党内主流批评后承认比喻不当并致歉。",
      "source": "每日经济新闻"
    },
    {
      "date": "2024-11",
      "topic": "公职选举法修正",
      "stance_content": "在李在明虚伪公开案一审判决后，提出删除公职选举法中虚伪事实公布罪的选举法修正案。",
      "source": "namu.wiki"
    },
    {
      "date": "2025-08",
      "topic": "合成尼古丁电子烟监管",
      "stance_content": "2025年8月提出将合成尼古丁归类为准药品的药事法修正案，主张加强对合成尼古丁电子烟的监管。",
      "source": "2Firsts报道"
    },
    {
      "date": "2024-11",
      "topic": "肥胖对策立法",
      "stance_content": "2024年11月发起《肥胖管理振兴法》等肥胖对策相关法案，将肥胖定义为国家健康危机。",
      "source": "Korea Bizwire报道"
    },
    {
      "date": "2026-02",
      "topic": "国民年金改革",
      "stance_content": "作为国民年金改革特别委员会委员参与年金改革讨论，认为仅靠改变一个制度无法实现年金改革。",
      "source": "朝鲜日报2026年2月报道"
    }
  ],
