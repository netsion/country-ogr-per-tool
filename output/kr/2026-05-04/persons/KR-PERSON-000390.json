  "political_stances": [
    {
      "date": "2024-06",
      "topic": "残障人权益与信息接览权保障",
      "stance_content": "主张扩大残障人信息接览权和文化享受权，代表发议著作权法、图书馆法、出版文化产业振兴法、游戏产业振兴法等多项修正案，推动为视障等印刷物接触困难人群提供无障碍图书、游戏和教育资料。每年制作不同残障类型的'Barrier-Free（无障碍）议政报告书'。",
      "source": "AbleNews (https://www.ablenews.co.kr/news/articleView.html?idxno=230675)"
    },
    {
      "date": "2024-09",
      "topic": "器官捐赠自主权",
      "stance_content": "主张器官捐赠者的自我决定权应优先于家属同意权，提出修正案允许本人生前明确登记捐赠意愿后，即使家属反对也可执行捐赠。同时关注精神保健福祉法改革，主张逐步将精神病院入院制度从家属同意制转向国家责任制。",
      "source": "医学新闻 (https://www.bosa.co.kr/news/articleView.html?idxno=2231503)"
    },
    {
      "date": "2024-12",
      "topic": "弹劾投票与民主责任",
      "stance_content": "在尹锡悦总统弹劾案表决中违党投票，表示'国会议员的责任和义务最为重要'，'作为代替市民行事的信差，做了理所当然的事'。戒严令发布时指出残障人在紧急状态下面临更严峻的困境——听障者无法获取手语翻译和字幕信息——体现了对弱势群体处境的深刻关注。",
      "source": "BBC韩语 (https://www.bbc.com/korean/articles/cd9xx9gzdpeo)"
    },
    {
      "date": "2023-06",
      "topic": "残障人政策与社会包容",
      "stance_content": "自称为'残障人当事者兼代表社会弱者的比例代表议员'，推动残障人虐待犯罪处罚法制定、残障人活动支援服务制度改善、视障者交通出行权保障等议题。倡导'弱者不是保护对象，而是一起前行的朋友'的理念。",
      "source": "联合新闻 (https://www.yna.co.kr/view/AKR20230615161700001)"
    }
  ],
