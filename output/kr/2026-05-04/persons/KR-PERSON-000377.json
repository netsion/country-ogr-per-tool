  "political_stances": [
    {
      "date": "2024-04",
      "topic": "朝鲜核问题与无核化",
      "stance_content": "主张通过韩美紧密合作对朝鲜施加强大压力，促使朝鲜放弃核武器。认为无核化尚未失败，需要持续耐心推进外交解决，强调朝鲜核问题作为历时30年的复杂问题需要长期外交努力。支持尹锡悦政府的「大胆构想」无核化路线图。",
      "source": "https://www.segye.com/newsView/20240409523242"
    },
    {
      "date": "2022",
      "topic": "韩美日三国合作",
      "stance_content": "强调韩美日三边合作在应对朝鲜核威胁和维护地区安全中的重要性。在担任朝鲜半岛和平交涉本部长期间积极推动三边安全合作框架。",
      "source": "https://namu.wiki/w/%EA%B9%80%EA%B1%B4(1966)"
    },
    {
      "date": "2026-02",
      "topic": "气候外交",
      "stance_content": "认为气候危机是跨越国界的问题，没有国际社会合作无法解决。主张将气候外交提升至国家战略层面进行系统化推进，并提出相关立法「地球拯救外交法」。",
      "source": "https://www.hkbs.co.kr/news/articleView.html?idxno=817949"
    },
    {
      "date": "2024",
      "topic": "AI技术与国家竞争力",
      "stance_content": "关注AI技术对国家安全和国际竞争力的影响，主张韩国应积极应对中美AI技术竞争，推动AI领域立法和规范建设，致力于使韩国成为AI世界三大强国之一。担任国民力量党AI世界三大强国跃升特别委员会委员。",
      "source": "https://ko.wikipedia.org/wiki/%EA%B9%80%EA%B1%B4_(1966%EB%85%84)"
    }
