  "political_stances": [
    {
      "date": "2026-03",
      "topic": "数据主权与信息安全",
      "stance_content": "高度重视国家数据主权保护，反对政府将精密地图数据向谷歌等海外企业无条件开放。主持国会'精密地图谷歌出境紧急诊断讨论会'，强调在数据出境前必须制定国内产业保护对策和信息安全审查强化方案，并主导《空间情报构建及管理法》修订案以加强国家空间情报保护。",
      "source": "国会讨论会及法案发起记录"
    },
    {
      "date": "2025-12",
      "topic": "农林民生政策",
      "stance_content": "持续关注农业人口生计问题，推动农业直接支付制度扩大化、农村空屋整顿税收支援、农业人税收减免延期等多项民生法案。主张将农外收入基准现实化，使更多青年农民和兼业农民受益于公益直接支付金制度。",
      "source": "法案发起及国会表决记录"
    },
    {
      "date": "2025-04",
      "topic": "山火防灾与灾后重建",
      "stance_content": "在2025年庆尚道特大山火灾害后积极推动灾后重建立法，促成'超大型山火灾害支援特别法'在国会山火特别委员会通过，并成功争取'南部圈国家山火防止中心'落户咸阳郡，强化区域防灾能力。",
      "source": "国会山火特别委员会记录"
    },
    {
      "date": "2024-12",
      "topic": "保守派立场",
      "stance_content": "属于保守阵营中亲李明博系出身的政治人物，后追随柳胜敏参与正党创党。2024年12月国会表决中赞成解除戒严要求决议案。2025年担任金文洙总统候选人庆南选区总括选举对策委员长，支持保守派候选人。",
      "source": "国会表决及政党活动记录"
    }
  ],
