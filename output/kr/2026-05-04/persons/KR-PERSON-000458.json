  "political_stances": [
    {
      "date": "2025-02",
      "topic": "AI产业发展与规制改革",
      "stance_content": "主张韩国应跃升为AI三大强国之一，呼吁削减不必要的人工智能领域规制，推动AI产业激活。认为中国DeepSeek的成功在于政府主导的AI战略和将14亿人口数据以开源方式开放，韩国应放松个人信息和数据规制，以开源方式促进产业应用。推动半导体特别法和电力网扩充特别法等亲企业法案尽快通过国会。",
      "source": "电子新闻 (https://www.etnews.com/20250219000147)"
    },
    {
      "date": "2024-11",
      "topic": "地区均衡发展与开发限制区制度改革",
      "stance_content": "批评'70年代式规制一刀切政策'阻碍地区均衡发展，主张改革开发限制区（绿地带）指定管理制度，推动地方城市合理开发和经济增长。关注昌原马山地区的南海岸旅游产业振兴和制造业升级。",
      "source": "韩国政策新闻 (https://www.k-policy.com/news_gisa/gisa_view.htm?gisa_idx=58026)"
    },
    {
      "date": "2025-06",
      "topic": "12·3紧急戒严与党内改革",
      "stance_content": "公开批评尹锡悦政府12·3紧急戒严是'时代错误的、明显的错误'，在国民力量党内部发起'接力反省文'运动，表示'不再躲在党论后面、不再顺应大势'，呼吁党内进行根本性改革和刷新。2025年6月辞去非常对策委员职务以示对党内问题的负责。",
      "source": "朝鲜日报 (https://www.chosun.com/politics/politics_general/2025/06/06/KM46TPUCPJEQVCEMMJUMFACBLQ/)"
