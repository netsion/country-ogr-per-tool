  "political_stances": [
    {
      "date": "2002-09",
      "topic": "性交易处罚与人权保护",
      "stance_content": "坚定支持对性交易行为的严厉处罚。2002年主导发起《性买卖特别法》（性买卖斡旋等行为的处罚及防止相关法律），以2002年群山开福洞火灾惨案为契机，推动性交易受害者人权保护立法，2004年该法正式实施。此后持续关注性交易受害者保护政策。",
      "source": "KBS新闻、女性新闻、国会立法记录"
    },
    {
      "date": "2025-11",
      "topic": "反堕胎与生命权保护",
      "stance_content": "持保守生命权立场。2025年11月代表发起《刑法》及《母子保健法》部分修订案，主张对堕胎行为维持刑罚规定，反对完全废止堕胎罪，认为应保护胎儿生命权。",
      "source": "Amnesty韩国声明、NewsPower报道、国会立法记录"
    },
    {
      "date": "2024",
      "topic": "反歧视法（差別禁止法）",
      "stance_content": "反对现行反歧视法案。认为反歧视法可能引发社会分裂，参加宗教团体联合记者会公开反对推进反歧视法立法，主张以现有法律框架足以应对歧视问题。",
      "source": "女性连带声明、Ntoday报道"
    },
    {
      "date": "2024-12",
      "topic": "尹锡悦总统弹劾",
      "stance_content": "在2024年12月尹锡悦总统弹劾政局中，作为湖南地区唯一执政党议员，坚定反对弹劾。缺席弹劾投票，反对内乱常设特检和内乱犯罪嫌疑人迅速逮捕要求案，并出席反弹劾集会发表演说。",
      "source": "全北日报、Newsis、No Cut News"
    }
  ],
