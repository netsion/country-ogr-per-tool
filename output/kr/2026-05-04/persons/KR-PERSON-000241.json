  "political_stances": [
    {
      "date": "2024-10",
      "topic": "科学技术R&D预算",
      "stance_content": "强烈批评尹锡悦政府大幅削减R&D预算的做法，主张恢复被削减的研发预算，确保科学技术研究人员能专心研究，推动韩国科技持续发展。",
      "source": "https://news.lghellovision.net/news/articleView.html?idxno=482669"
    },
    {
      "date": "2024-10",
      "topic": "放送媒体制度改革",
      "stance_content": "批评现政府利用放送通信委员会和放送审议委员会等机构压制媒体自由，主张推动放送通信媒体法改革，保障国民知情权和公共媒体独立性。",
      "source": "https://news.lghellovision.net/news/articleView.html?idxno=482669"
    },
    {
      "date": "2024-10",
      "topic": "深度伪造（Deepfake）犯罪对策",
      "stance_content": "批评放送通信审议委员会对深度伪造性犯罪应对不力，指出委员会对Telegram等平台未采取积极措施，要求政府强化预防性措施和监管。",
      "source": "https://news.lghellovision.net/news/articleView.html?idxno=482669"
    },
    {
      "date": "2025-01",
      "topic": "网络使用费（망 사용료）立法",
      "stance_content": "认为YouTube、Netflix等全球平台利用韩国网络基础设施却不支付使用费，造成国内业者逆差别对待。已提出网络使用费相关法案，主张建立公平有序的放送市场秩序以激活地方文化放送。",
      "source": "https://news.lghellovision.net/news/articleView.html?idxno=534299"
    },
    {
      "date": "2025-01",
      "topic": "基本社会（기본사회）基本法",
      "stance_content": "提出基本社会实现基本法，主张在AI和机器人替代劳动的时代，国家应保障国民在照护、居住、教育、医疗等方面的基本权利，并推动社会连带经济发展。",
      "source": "https://news.lghellovision.net/news/articleView.html?idxno=534299"
    },
    {
      "date": "2025-01",
      "topic": "高阳新沙线等西北部交通基础设施建设",
      "stance_content": "主张将三松至恩平新城、延新内至江南新沙的高阳新沙线路线纳入第5次国家铁道网计划，强调应扩大均衡发展指数，将交通拥堵度和未来需求纳入经济妥当性评估，避免江北地区被边缘化。",
      "source": "https://news.lghellovision.net/news/articleView.html?idxno=534299"
    },
    {
      "date": "2025-01",
      "topic": "与祖国革新党合党论",
      "stance_content": "认为合党论是政治圈而非国民的诉求，当前应优先处理内乱克服、国政正常化、民生恢复等国民性课题，而非急于讨论合党。主张应先听取国民意见、经过充分的党内讨论和合议程序。",
      "source": "https://news.lghellovision.net/news/articleView.html?idxno=534299"
    },
    {
      "date": "2026-04",
      "topic": "放送通信发展基金制度改革",
      "stance_content": "主办放送媒体通信委员会时代放送通信发展基金制度改善方案讨论会，指出地区基础综合有线放送事业者（SO）面临的结构性问题，主张重新设计放送通信发展基金制度以反映产业现实。",
      "source": "https://news.tvchosun.com/site/data/html_dir/2026/04/23/2026042390266.html"
    },
    {
      "date": "2025-09",
      "topic": "12.12军事叛乱",
      "stance_content": "在国会科学技术情报放送通信委员会上发言谴责12.12军事叛乱，体现其对民主化价值的坚定立场。",
      "source": "https://namu.wiki/w/%EA%B9%80%EC%9A%B0%EC%98%81(1969)"
    }
