  "political_stances": [
    {
      "topic": "保健福利政策",
      "stance_content": "作为国会保健福祉委员会委员，重点推动国民健康保险制度改革、精神健康福利体系完善、老人长期疗养保险制度可持续性等民生议题。",
      "source": "国会保健福祉委员会活动"
    },
    {
      "topic": "地方行政与区域发展",
      "stance_content": "主张大田与锦山合并而非大田-忠南全面行政统合，提出忠清圈超级城市构想，强调地方分权和区域均衡发展。",
      "source": "中道新闻采访（2025-02）"
    },
    {
      "topic": "危机家庭支援",
      "stance_content": "代表发起了'危机家庭职权支援三法'，旨在完善社会福利安全网，防止弱势群体因福利盲区而发生悲剧事件。",
      "source": "Instagram官方账号（2025-10）"
    },
    {
      "topic": "食品安全",
      "stance_content": "代表发起《进口食品安全管理特例法》修正案，加强对进口食品的检验监管力度，保障国民食品安全。",
      "source": "GCN报道（2025-10）"
    }
  ],
