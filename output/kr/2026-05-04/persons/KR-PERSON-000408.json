  "political_stances": [
    {
      "date": "2024-07",
      "topic": "蔡上兵特检法反对",
      "stance_content": "坚决反对在野党主导的'蔡上兵特检法'，认为该法案是特定政治派别为政治利益而推动的，并非真正为查明真相，通过长达6小时49分钟的冗长辩论进行阻击。同时担任殉职海军陆战队调查妨碍等国政调查特别委员会委员。",
      "source": "NamuWiki (https://namu.wiki/w/박준태(정치인))"
    },
    {
      "date": "2024-12",
      "topic": "12·3戒严事件与弹劾案",
      "stance_content": "政治立场为亲尹派，2024年12月3日戒严事件中缺席戒严解除要求决议案投票，12月7日缺席尹锡悦总统弹劾追诉案投票，并前往总统官邸阻止逮捕尹锡悦。",
      "source": "OhmyNews (https://www.ohmynews.com/NWS_Web/Series/series_premium_pg.aspx?CNTN_CD=A0003158436)"
    },
    {
      "date": "2026-04",
      "topic": "不孕治疗支援政策",
      "stance_content": "主张全面取消第一胎不孕治疗费用的支援次数限制，大幅降低健康保险本人负担率，认为现行制度的次数限制无法充分反映不孕治疗需要反复进行的特性，导致部分患者被迫放弃治疗。",
      "source": "iBabyNews (https://www.ibabynews.com/news/articleView.html?idxno=150338)"
    }
  ],
