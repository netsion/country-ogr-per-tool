  "political_stances": [
    {
      "date": "2025-01",
      "topic": "海洋产业发展与地区经济振兴",
      "stance_content": "主张将釜山中区、影岛区打造为海洋城市的核心枢纽，推动海洋集群、造船所和影岛凤来洞·水缆场的开发，以海洋水产业为中心振兴地区经济，将影岛建设为'海洋首都的中心'。",
      "source": "News2Day专访 (https://www.news2day.co.kr/article/20250113500216)"
    },
    {
      "date": "2024-07",
      "topic": "船员权益改善与人力短缺应对",
      "stance_content": "认为韩国船员因恶劣工作环境和待遇导致人力减少及老龄化问题严峻，主导修订《船员法》，强化船员权益保护，增设不当解雇时雇主履行命令的强制履行金制度，明确长官职责包括船员待遇改善和收入增加。",
      "source": "联合新闻、警察TV等多家媒体报道"
    },
    {
      "date": "2024",
      "topic": "人口减少地区发展与旧城区改造",
      "stance_content": "关注釜山中区、影岛区人口流出和旧城区衰退问题，推动《人口减少地区支援特别法》修订案，主张空屋实态调查和旧城区开发条件改善，举办'旧城区开发条件营造及搞活方案'讨论会，致力于居住环境改善和商圈激活。",
      "source": "News2Day专访 (https://www.news2day.co.kr/article/20250113500216)"
    },
    {
      "date": "2025-01",
      "topic": "海洋观光与新兴海洋产业",
      "stance_content": "在预算决算特别委员会全体会议上主张扩大海洋观光和新兴海洋产业支持，为中区和影岛区发掘新增长动力。",
      "source": "News2Day专访 (https://www.news2day.co.kr/article/20250113500216)"
    }
  ],
