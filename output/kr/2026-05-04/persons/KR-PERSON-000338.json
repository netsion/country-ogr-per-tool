  "political_stances": [
    {
      "date": "2025-12",
      "topic": "人工智能与数字平等",
      "stance_content": "主张政府应确保所有国民平等获取AI技术的机会，推动立法为低收入层和青少年提供AI使用费支援，防止因经济原因导致的数字鸿沟扩大化。作为AI基本法的代表发起人，强调地方政府在AI发展中的角色。",
      "source": "https://www.dailiang.co.kr/news/articleView.html?idxno=230032"
    },
    {
      "date": "2025-09",
      "topic": "劳动安全与重大产业灾害处罚",
      "stance_content": "主张对反复发生重大产业灾害的事业主处以最高100亿韩元的过征金，推动《产业安全保健法》修订，强调仅靠现有重处罚法不足以改善现场安全，需对企业施加实质性经济负担。",
      "source": "https://www.pressian.com/pages/articles/2025090915082338336"
    },
    {
      "date": "2025-07",
      "topic": "地区均衡发展与去首都圈一极化",
      "stance_content": "积极推动'都市融合特区3法'，主张解决首都圈一极化问题，通过在大田等地方城市设立融合特区，营造创新产业集聚空间，实现全国均衡发展。提出'大德3.0'构想，力图将大德研究开发特区打造为超越板桥的创新枢纽。",
      "source": "https://www.iusm.co.kr/news/articleView.html?idxno=1052511"
    },
    {
      "date": "2025-02",
      "topic": "政治参与平等化",
      "stance_content": "发起'平等政治寄附法'（平等政治捐款法），主张不应仅限特定阶层参与政治资金捐助，应为低收入层、学生、退休者等所有选民保障政治参与权利。",
      "source": "https://m.joongdo.co.kr/view.php?key=20250226010008381"
    },
    {
      "date": "2026-01",
      "topic": "大田-忠南行政统合",
      "stance_content": "主张推进大田广域市与忠清南道的行政统合，创建'新首都圈'。2026年1月宣布参选大田-忠南统合广域团体长，提出将大田打造为超越首尔的经济中心的愿景。",
      "source": "https://www.theia.global/article/rep-jang-cheol-min-declares-candidacy-for-daejeon-south-chungcheong-integrated-mayor-election-2026-6"
