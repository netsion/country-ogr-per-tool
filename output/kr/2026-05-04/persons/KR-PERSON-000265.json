  "political_stances": [
    {
      "date": "2020-12",
      "topic": "检察改革",
      "stance_content": "朴范界在被提名为法务部长官后明确表示将\"完成检察改革\"，承诺倾听国民声音推进检察改革第二阶段，主张强化检察调查的公正性与中立性。",
      "source": "https://news.kbs.co.kr/news/view.do?ncd=5083896"
    },
    {
      "date": "2021-04",
      "topic": "检察总长人选标准",
      "stance_content": "朴范界就任法务部长官后表示下一任检察总长的条件应与\"总统的国政哲学具有相关性\"，引发政治中立性争议后收回发言表示\"将慎重留意\"。",
      "source": "https://www.chosun.com/national/court_law/2021/04/23/2FNHDXSR6NFX7PNX6WIJ4VWJ54/"
    },
    {
      "date": "2021-04",
      "topic": "反对废除调查指挥权",
      "stance_content": "朴范界公开反对候任总统尹锡悦提出的废除法务部长官调查指挥权、检察预算编制权独立等司法改革承诺，主张\"在确保检察调查公正性和中立性之前，不应先行废除调查指挥权\"。",
      "source": "https://news.sbs.co.kr/news/endPage.do?news_id=N1006687457"
    },
    {
      "date": "2020-11",
      "topic": "评价尹锡悦",
      "stance_content": "朴范界评价时任检察总长尹锡悦\"显然怀有政治野心\"，批评其行为超越了检察总长的职责范畴。二人同为第33届司法考试合格者、司法研修院第23期同期。",
      "source": "https://v.daum.net/v/A6TGsUsFzm"
    },
    {
      "date": "2024-12",
      "topic": "尹锡悦弹劾案",
      "stance_content": "朴范界担任共同民主党弹劾委员团成员，积极参与推动尹锡悦总统弹劾审判程序，并呼吁迅速进行弹劾审判。",
      "source": "https://www.mk.co.kr/en/politics/11196335"
    },
    {
      "date": "2017-05",
      "topic": "朴槿惠弹劾及积弊清算",
      "stance_content": "朴范界担任共同民主党积弊清算委员会委员长，积极推动对朴槿惠政府时期\"崔顺实干政事件\"的调查问责，主张彻底清算历史积弊。",
      "source": "https://namu.wiki/w/%EB%B0%95%EB%B2%94%EA%B3%84"
    }
  ],
