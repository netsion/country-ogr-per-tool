  "political_stances": [
    {
      "date": "2026-04-22",
      "topic": "庶民金融支援 / 休眠存款利用",
      "stance_content": "提出《庶民金融生活支援法部分修正法案》，主张金融机构强制缴纳休眠存款，并将休眠存款10年后适用消灭时效，以此扩大韩国庶民金融院的财源规模，将沉睡的金融资源转化为低收入群体实际支援。",
      "source": "https://www.mk.co.kr/en/politics/12023943"
    },
    {
      "date": "2025-12-16",
      "topic": "边境地区创业中小企业税收支援",
      "stance_content": "提出边境地区创业中小企业税制强化法案，主张将边境地区从过密抑制圈域规制中排除，使其获得与非首都圈同等水平的税收优惠待遇。",
      "source": "https://www.mygoyang.com/news/articleView.html?idxno=86974"
    },
    {
      "date": "2024-08-28",
      "topic": "国家财政法 / 企划财政部违法",
      "stance_content": "批评企划财政部无视法律规定，通过减额支出方式截留应支付至2025年的交付税，违反相关法律，称将考虑告发。",
      "source": "https://www.fnnews21.com/news/articleView.html?idxno=43574"
    },
    {
      "date": "2026-01-06",
      "topic": "战略出口金融支援",
      "stance_content": "在国会财政经济规划委员会战略出口金融支援法听证会上强调，当今大规模出口接单不仅依赖企业的价格和技术竞争力，需要国家层面系统性金融支援机制。",
      "source": "https://www.facebook.com/younghwan.kim.980/posts/25277073821963250"
    },
    {
      "date": "2024-11",
      "topic": "经济政策 / 国政监查",
      "stance_content": "在国政监查中尖锐质询尹锡悦政府经济政策失误，基于差异化数据分析，系统指出出口与内需之间的增长差距、个体户倒闭率、青年就业问题及高汇率问题等经济政策全局性缺陷。获2024年国政监查优秀议员及每日经济国政监查记分板大奖。",
      "source": "https://www.mygoyang.com/news/articleView.html?idxno=82280"
    }
  ],
