  "political_stances": [
    {
      "date": "2018-01-12",
      "topic": "国家情报院改革",
      "stance_content": "发起国家情报院法修订案，核心内容包括将国家情报院对共搜查权移交警察、设立独立于国政院的情报监察官制度、强化国会为中心的内外部管理监督功能，以彻底阻断情报机关介入国内政治。提出将国政院更名为\"安保情报院\"。",
      "source": "https://news.kbs.co.kr/news/view.do?ncd=3593387"
    },
    {
      "date": "2020-08-04",
      "topic": "国家情报院改革（第二轮立法）",
      "stance_content": "以国会情报委员会干事身份代表发起国政院改革法案，主张删除国政院国内保安信息收集功能、对共搜查权移交警察、设立独立情报监察官制度，强调\"国政院改革不能依赖政权或个人的善意，必须以法律和制度实现民主管控\"。",
      "source": "https://www.yna.co.kr/view/AKR20200804166700001"
    },
    {
      "date": "2020-12-14",
      "topic": "国家情报院改革法通过",
      "stance_content": "推动国政院改革法案历时三年最终在国会全体会议通过，表示\"国政院改革不能依赖人的善意已经历届政府事例证实，必须通过法律和制度来保障\"。",
      "source": "https://www.straightnews.co.kr/news/articleView.html?idxno=89674"
    },
    {
      "date": "2022-09-16",
      "topic": "亲文兼亲明（亲李在明）政治立场",
      "stance_content": "公开声明\"我是亲文（亲文在寅）也是亲明（亲李在明）\"。在2022年党内要求李在明退出党首竞选时，作为再选议员中唯一公开反对者力挺李在明，并组建亲明系Telegram聊天室推动组织性支援。",
      "source": "https://www.joongang.co.kr/article/25102342"
    },
    {
      "date": "2025-06-13",
      "topic": "改革立法与执政路线",
      "stance_content": "当选院内代表后表示\"从现在起六个月是改革的黄金时间，改革要成功需要有成功的经验\"，承诺在一年内完成检察、司法、媒体改革，推动追加更正预算案和主要立法。",
      "source": "https://www.mk.co.kr/news/politics/11342035"
    },
    {
      "date": "2025-06-13",
      "topic": "李在明政府支持",
      "stance_content": "以\"李在明的黑色特工（블랙요원）\"和\"最终兵器\"为竞选口号，表示\"唯以李在明政府的成功为宗旨奉献一切\"，体现鲜明亲明强硬路线。",
      "source": "https://www.yna.co.kr/view/AKR20250613121300001"
    }
  ],
