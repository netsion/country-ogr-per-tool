  "political_stances": [
    {
      "date": "2023",
      "topic": "外交安全",
      "stance_content": "亲美保守派，强调韩美同盟和韩日合作的重要性，批评文在寅政府的亲北倾向外交，支持尹锡悦政府的价值外交路线。主张对朝鲜采取强硬立场，反对对朝绥靖政策。支持加强韩美日三边安全合作。",
      "source": "国会发言及媒体报道"
    },
    {
      "date": "2024",
      "topic": "经济产业",
      "stance_content": "积极推动蔚山地方产业发展，主导引进二次电池（蓄电池）特化园区，推进世界首批氢能有轨电车开工，致力于将蔚山建设为氢能产业先导城市。支持传统能源与新能源产业并重发展。",
      "source": "选举承诺及国会活动"
    },
    {
      "date": "2023",
      "topic": "福利政策",
      "stance_content": "对现有福利制度持批评态度，主张选择性福利而非普遍性福利，认为过度福利加重财政负担。曾在竞选期间提出千元早餐等民生政策。",
      "source": "政治报道及竞选纲领"
    },
    {
      "date": "2024",
      "topic": "宪政法治",
      "stance_content": "作为法官出身的政治人，强调法治和宪政秩序的重要性。在2024年戒严风波中被指为亲尹核管（亲尹锡悦核心人物），反对弹劾尹锡悦总统。",
      "source": "媒体报道及国会表决记录"
    }
  ],
