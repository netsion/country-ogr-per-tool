  "political_stances": [
    {
      "date": "2024-02",
      "topic": "天安舰事件官方调查结论质疑",
      "stance_content": "卢钟勉在2014年曾发表言论称'使用天安舰被炸沉（폭침）一词的所有媒体都是假新闻'，质疑政府关于天安舰被朝鲜鱼雷击沉的官方调查结论。该言论在2024年总选期间被国民力量党批评为'天安舰阴谋论'，卢钟勉则反驳称这是对问题意识的抹杀和噤声行为，并指出《朝鲜日报》在天安舰事件次日的社论中也对政府结论提出了类似的质疑。",
      "source": "https://www.mediatoday.co.kr/news/articleView.html?idxno=315623"
    },
    {
      "date": "2024-10-31",
      "topic": "明太均出席国会监查呼吁",
      "stance_content": "作为共同民主党院内代发言人，卢钟勉发表书面简报，敦促政治掮客明太均（명태균）出席国会监查并公布真相，指出明太均接受媒体采访却拒绝出席国会监查的行为不可接受。",
      "source": "https://www.news33.net/news/articleView.html?idxno=106031"
    },
    {
      "date": "2025-08-05",
      "topic": "广播三法改革与冗长辩论",
      "stance_content": "卢钟勉在国会全体会议上就广播法修正案进行了长达9小时5分钟的冗长辩论（필리버스터），逐一列举了韩国新闻史上的重大误报案例（从1945年托管统治误报到世越号'全员救援'误报），强调广播的公共性和公正性，主张通过修订广播法保障报道专业频道的独立性和自主性，防止权力对媒体的干预。",
      "source": "https://www.incheontoday.com/news/articleView.html?idxno=306374"
    },
    {
      "date": "2025-12-08",
      "topic": "打击虚假伪造信息立法",
      "stance_content": "作为共同民主党媒体改革特别委员会干事，卢钟勉表示'将赢得针对虚假伪造信息的立法战争'，推动《信息通信网法》修正案，引入对恶意虚假信息传播的惩罚性赔偿制度，但将YouTube等内容平台与传统媒体区分规制。",
      "source": "https://www.mediaus.co.kr/news/articleView.html?idxno=315448"
    },
    {
      "date": "2025-12-14",
      "topic": "信息通信网法修正案与言论自由",
      "stance_content": "卢钟勉在记者恳谈会上就《信息通信网法》修正案说明称，该修正案是由法院判断虚假信息，并非政府进行言论控制，反驳了反对派关于'言论统制'的批评。",
      "source": "https://m.news.nate.com/view/20251214n10485"
    },
    {
      "date": "2025-08-05",
      "topic": "劳动组合权利与罢工保护",
      "stance_content": "在冗长辩论中，卢钟勉援引国际劳动组织（ILO）的建议，主张删除不将特定团体视为劳动组合的规定，并批评罢工后面临的损害赔偿请求和财产保全措施实质上是'致命性'的压制手段，反对保守阵营和媒体将罢工工人贴上'非法集团'标签的做法。",
      "source": "https://www.newscj.com/news/articleView.html?idxno=3301740"
    }
  ],
