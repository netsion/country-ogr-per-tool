  "political_stances": [
    {
      "date": "2012",
      "topic": "地方分权与自治",
      "stance_content": "长期倡导地方分权改革，认为'真正市民民主主义从地方开始'。2012年起任地方分权改宪国民行动共同议长，2017年起任全国自治分权改宪推进本部共同代表。推动地方自治法全盘修订，使人口超百万城市获得特别市地位。",
      "source": "세계일보 2024-05-14; 동아일보 2024-05-24"
    },
    {
      "date": "1994",
      "topic": "环保与气候危机",
      "stance_content": "环保运动家出身，关注气候危机应对与可持续发展。曾推动水原川自然河川修复工程，倡导地方政府的绿色新政与气候危机应对政策。现任国会气候危机特别委员会委员。",
      "source": "광교신문; 国会议员所属委员会信息"
    },
    {
      "date": "2024-06",
      "topic": "传世诈骗（전세사기）受害者保护",
      "stance_content": "将传世诈骗受害者救助作为第22届国会1号法案提出，推动'传世诈骗特别法'修订，引入'押金1/3最低保障制度'，由国家保障传世诈骗受害者的最低押金回收。2024年8月该法案首次在国会本会议通过，但遭总统否决；2026年4月修订案再次通过本会议。",
      "source": "뉴스핌 2026-04-23; 경기일보 2024-08-28"
