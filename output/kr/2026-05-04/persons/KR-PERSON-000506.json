  "political_stances": [
    {
      "date": "2015-04",
      "topic": "税收与福利政策",
      "stance_content": "公开批评朴槿惠政府的'无增税福利'政策，指出'无增税福利已被证明是虚假的'，主张以'中负担-中福利'为长期目标，认为富人和大企业应承担更多税负，法人税不应成为禁区。",
      "source": "维基百科/国会交涉团体代表演讲"
    },
    {
      "date": "2015-06",
      "topic": "宪政与国会权力",
      "stance_content": "坚持主张国会法修正案，允许国会要求修改政府施行令，认为这是维护三权分立和国会立法权的重要机制，因此与朴槿惠总统发生严重冲突，最终被迫辞去院内代表职务。",
      "source": "维基百科/韩国政治纪实"
    },
    {
      "date": "2016-12",
      "topic": "朴槿惠弹劾",
      "stance_content": "在执政党内率先支持弹劾朴槿惠总统，称'读了检方起诉书后认为弹劾不可避免'，主张以'正义存续的共和主义'为原则参与弹劾表决。",
      "source": "维基百科/韩国国会记录"
    },
    {
      "date": "2017-04",
      "topic": "外交安全政策",
      "stance_content": "主张部署萨德反导系统、重新部署战术核武器或实行核共享，坚持对朝鲜实施强力压迫与制裁，反对文在寅政府对北对话乞求姿态，批评'韩半岛绕过（Korea Passing）'现象。",
      "source": "2017年总统竞选纲领/维基百科"
    },
    {
      "date": "2017-05",
      "topic": "经济改革",
      "stance_content": "提出'经济改革、安保保守'的竞选口号，批评文在寅政府'收入主导增长'理论为'幻想'和'愚蠢'，主张以创新增长为核心的经济政策，改革财阀经济体制，推动劳动市场灵活性。",
      "source": "2017年总统竞选辩论/维基百科"
    },
    {
      "date": "2016-05",
      "topic": "共和主义政治哲学",
      "stance_content": "以共和主义为自身政治哲学核心，定义为'在保障公共善的法治下，公民不受其他公民支配地享有自由并践行公民德性的政治秩序'，强调正义为共和主义最重要的价值，主张超越民主主义、实现'温暖的、正义的保守'。",
      "source": "成均馆大学演讲/《我为什么从政》"
    },
    {
      "date": "2025-01",
      "topic": "宪政危机与党内改革",
      "stance_content": "公开批评国民力量党未对尹锡悦总统的内乱嫌疑进行反思，称'国民力量党对将尹锡悦检察官推为总统候选人却未能阻止其暴政负有沉重责任'，主张党应向国民跪地谢罪、恢复良知。",
      "source": "脸书/韩联社"
    },
    {
      "date": "2025-03",
      "topic": "对韩东勋的评价",
      "stance_content": "批评韩东勋的政治哲学不明确，称'不知道韩东勋的政治哲学是什么'，强调真正的保守应以共和主义为基础，包含让人民安居乐业、社会福利保障等公共善的追求。",
      "source": "朝鲜日报采访"
    }
  ],
