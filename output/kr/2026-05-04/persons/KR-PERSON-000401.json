  "political_stances": [
    {
      "date": "2024",
      "topic": "财政纪律与国家财政准则",
      "stance_content": "代表发起'尹锡悦政府财政准则'国家财政法修正案，主张在政府编制预算时应将GDP对管理财政收支比率控制在3%以内，当国家债务比率超过60%时应将该比率下调至2%，同时在战争、灾害、经济衰退等内外环境变化时允许财政弹性应对。强调健全的财政纪律是经济可持续增长的基石。",
      "source": "IssueN (https://issuen.kr/article/1065578552695023)"
    },
    {
      "date": "2022",
      "topic": "广播媒体公正性与反偏见报道",
      "stance_content": "担任国民力量党MBC偏向报道真相查明特别委员会委员长，推动广播法修订，主张公共广播电视机构应保持政治中立，反对偏向性报道。曾就广播法修正案程序与内容的偏向性问题主持国会讨论会，推动媒体公平立法。",
      "source": "联合新闻 (https://www.yna.co.kr/view/AKR20220722104300001)"
    },
    {
      "date": "2023-04",
      "topic": "护士法立法调解",
      "stance_content": "在国民力量党与行政部门的协商框架下，代表发起了护士法调解方案，在执政党与在野党就护士法立法问题僵持不下时，发挥了重要的政策协调作用。",
      "source": "NamuWiki (https://namu.wiki/w/%EB%B0%95%EB%8C%80%EC%B6%9C)"
    },
    {
      "date": "2021",
      "topic": "房地产税制改革",
      "stance_content": "在国会企划财政委员会国政监察中，强烈批评政府为抑制房价而上调房产税的政策，指出'用增税来压房价的做法再次失败'，主张应通过供给侧扩大而非增税来稳定房地产市场。",
      "source": "NewsJinju (https://www.newsjinju.kr/news/articleView.html?idxno=52581)"
    }
  ],
