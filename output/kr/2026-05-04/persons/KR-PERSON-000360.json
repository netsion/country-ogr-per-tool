  "political_stances": [
    {
      "topic": "言论改革与广播法修订",
      "stance_content": "积极推动「广播三法」修订，主张保障广播公司的政治中立性，防止政治偏颇报道和空降人事，强化广播委员会委员的独立性和专业性。作为民主党言论改革TF团长，主导广播法改革议程。",
      "source": "https://www.maeilnews.kr/news/article.html?no=31291"
    },
    {
      "topic": "检察改革",
      "stance_content": "强烈支持检察改革，反对政治检察官的「公告栏政治」行为，主张对检察官的不当政治干预行为进行监察。担任民主党政治检察捏造起诉应对特别委员会委员长，推动检调分离和检察民主化。",
      "source": "https://www.donga.com/news/Politics/article/all/20260318/133555641/2"
    },
    {
      "topic": "民生经济与公平竞争",
      "stance_content": "主张根绝生活物价串通和市场扰乱行为，提出「民生公正经济五大公约」，包括设立民生物价特别司法警察、打击哄抬物价和串通投标等，保障市民经济权益。",
      "source": "https://www.kyeongin.com/article/1759866"
    },
    {
      "topic": "国土交通与城市发展",
      "stance_content": "关注1期新城市再生整备和3期新城市供应，主张推进首都圈交通一体化体系，改善高阳市德阳区城市基础设施，推动新城市建设与老城区再开发的均衡发展。长期在国会国土交通委员会任职。",
      "source": "https://www.kyeongin.com/article/1760503"
    }
  ],
