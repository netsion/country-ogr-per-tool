  "political_stances": [
    {
      "date": "2023-06",
      "topic": "年龄计算法统一（满年龄法）",
      "stance_content": "主导推动《民法》及《行政基本法》部分修正案，将韩国长期混用的'虚岁'、'年岁'等年龄计算方式统一为国际通用的'满年龄'（만 나이），消除因年龄计算混乱导致的社会经济损失和日常生活不便。该法案于2023年6月正式施行。",
      "source": "国会义政大奖 (https://www.the-news24.co.kr/news/articleView.html?idxno=21583)"
    },
    {
      "date": "2025-07",
      "topic": "继承税改革与自由经济立法",
      "stance_content": "代表发起《继承税及赠与税法》修正案，主张将继承税率从50%下调至30%（与OECD平均水平接轨），废除最大股东20%溢价评估制度，减轻企业及家业继承负担，改善投资环境，激活民间经济。获2025年自由经济立法奖。",
      "source": "江原道民日报 (https://www.kado.net/news/articleView.html?idxno=2020295)"
    },
    {
      "date": "2025-12",
      "topic": "国政监查与权力机构问责",
      "stance_content": "在国会运营委员会国政监查中，强力质疑总统室人事介入嫌疑与权限滥用问题，指出国会特别活动费公开的双重标准，要求恢复权力机关的责任性与中立性，推动国会运营正常化。连续三年获国利民福奖。",
      "source": "大韩日报 (https://www.daehanilbo.co.kr/news/articleView.html?idxno=64092)"
    },
    {
      "date": "2024-06",
      "topic": "反李在明司法立场",
      "stance_content": "担任国民力量党'李在明司法破坏阻止特别委员会委员长'，积极推动对共同民主党代表李在明的司法调查，反对执政党方向的'防弹立法'，主张法治优先。",
      "source": "韩语维基百科 (https://ko.wikipedia.org/wiki/유상범_(1966년))"
    }
  ],
