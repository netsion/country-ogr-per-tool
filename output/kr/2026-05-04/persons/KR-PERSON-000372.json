  "political_stances": [
    {
      "date": "2024-06",
      "topic": "半导体产业政策",
      "stance_content": "主张国家层面大力支持半导体产业发展，认为半导体是韩国经济的核心支柱。亲自起草并代表提出了韩国历史上首部《半导体产业竞争力强化特别法》，推动建立政府层面的半导体产业战略支持体系，包括研发投入、人才培养和基础设施建设等方面。",
      "source": "https://www.businesskorea.co.kr/news/articleView.html?idxno=219495"
    },
    {
      "date": "2024",
      "topic": "青年发展与教育",
      "stance_content": "高度关注韩国青年面临的就业和未来发展规划问题，认为这是其步入政界的核心动力。创办'周六校园'知识共享平台，以自身四十余年产业经验无偿指导青年，构想建设'现代式书院'以培养下一代人才。",
      "source": "https://www.asiae.co.kr/article/2026043009391555953"
    },
    {
      "date": "2024",
      "topic": "AI与尖端产业",
      "stance_content": "积极推动韩国成为全球AI三大强国之一，担任国民力量党AI与半导体尖端产业特别委员会委员长，主张加强AI基础设施建设和相关政策立法，提升国家在半导体、人工智能等尖端产业领域的全球竞争力。",
      "source": null
    },
    {
      "date": "2025",
      "topic": "劳动制度改革",
      "stance_content": "曾提出《劳动基准法》修正案，主张对从事国家高科技战略产业研发工作的劳动者排除每周52小时工作制的适用限制，以增强韩国科技产业的国际竞争力。",
      "source": "https://www.mk.co.kr/en/economy/11159626"
    }
  ],
