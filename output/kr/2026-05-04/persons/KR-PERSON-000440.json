  "political_stances": [
    {
      "date": "2023-01",
      "topic": "加德岛新机场建设",
      "stance_content": "强烈推动加德岛新机场建设，认为这是釜山及东南圈经济发展的核心基础设施。2023年1月以国民力量党釜山全体15名议员联名方式主导发起《加德岛新机场建设公团法》，主张设立专门建设公团以加速推进新机场建设进程，同年9月法案在国会修正通过。",
      "source": "https://www.inews24.com/view/1562796"
    },
    {
      "date": "2021-12",
      "topic": "釜田—马山广域铁路",
      "stance_content": "积极推动釜田至马山广域铁路项目，2021年成功争取到30亿韩元项目预算用于电动车辆购置，视为连通釜山与庆南、促进区域经济一体化的重要交通动脉。",
      "source": "https://sensepeople.tistory.com/entry/%EC%A0%95%EC%B9%98%EC%9D%B8-%EC%9D%B4%ED%97%8C%EC%8A%B9-%ED%94%84%EB%A1%9C%ED%95%84-%EC%A0%95%EB%B3%B4"
    },
    {
      "date": "2022-04",
      "topic": "2030釜山世博会申办",
      "stance_content": "作为总统职务交接委员会2030釜山世博会申办TF团长，全力推动釜山申办2030年世界博览会，主张这将大幅提升釜山国际地位并带动韩国东南部地区全面发展。",
      "source": "https://ko.wikipedia.org/wiki/%EC%9D%B4%ED%97%8C%EC%8A%B9"
    },
    {
      "date": "2022-07",
      "topic": "国防安全与韩美同盟",
      "stance_content": "作为第21代国会国防委员会委员长，强调加强国防力量和巩固韩美同盟关系的重要性，关注海军舰艇及海洋人力资源的扩充，积极推动相关立法。",
      "source": "https://www.yna.co.kr/view/AKR20220722131100001"
    },
    {
      "date": "2025-06",
      "topic": "政党中立与整合",
      "stance_content": "在党内以无派系色彩著称，2025年6月参选国民力量党院内代表时强调超越派系、实现党内整合的必要性，主张'困难时期资深议员应当率先站出来解决问题'，提出'所有人的院内代表'理念。",
      "source": "https://www.yna.co.kr/view/AKR20250614037551001"
