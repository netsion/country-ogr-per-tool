  "political_stances": [
    {
      "date": "2024-03",
      "topic": "国家安全与国防政策",
      "stance_content": "主张\"阻止安保政治化\"，强调安保不是意识形态工具而是生存问题。作为军人出身的国会议员，强调以实际战力为基础的遏制力建设，反对将国防议题沦为政治斗争工具。",
      "source": "国民力量党竞选引才声明 / 韩国经济日报"
    },
    {
      "date": "2025-07",
      "topic": "反对恢复9·19南北军事协议",
      "stance_content": "强烈反对李在明政府恢复9·19南北军事协议的承诺，批评该协议为\"屈从性协议\"。联合国民力量党国防委员共同主办\"朝鲜敌对性两国论与屈从性9·19军事协议恢复是否为答案\"政策讨论会，主张以强有力的对朝遏制力取代对朝绥靖。",
      "source": "国会国防委员会政策研讨会 / e-newsp报道"
    },
    {
      "date": "2025-12",
      "topic": "总统安保观批评",
      "stance_content": "批评李在明总统在外信记者招待会上的安保发言，指出\"安保不是文字游戏而是冷酷的现实\"，认为总统对朝鲜绑架国民问题的态度轻率，要求政府立即端正安保观、确立安保态势。",
      "source": "TV朝鲜新闻报道 / 强善荣Facebook"
    },
    {
      "date": "2026-04",
      "topic": "国防研发与自主国防",
      "stance_content": "主办\"国防研发（R&D）体制发展国会政策讨论会\"，强调以尖端技术实现自主国防，推动国防研发体系现代化。主张加大国防科研投入，提升韩国自主武器系统开发能力。",
      "source": "国会国防委员会 / 国防日报报道"
    },
    {
      "date": "2025",
      "topic": "脱北者保护政策",
      "stance_content": "主导推进《朝鲜脱北居民保护法》修正案，要求统一部长官有义务为脱北者的人权与人身安全制定并实施保护政策，强调\"保护冒死寻找自由的脱北者是国家基本使命\"。",
      "source": "今日EToday报道"
    }
  ],
