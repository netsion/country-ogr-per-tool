  "political_stances": [
    {
      "date": "2024-06",
      "topic": "假新闻规制与平台责任",
      "stance_content": "作为第22届国会1号法案，主导发起了'信息通信网利用促进及信息保护等相关法律'修正案（即'假新闻阻断义务化法'），要求Naver、YouTube等信息通信服务提供者承担虚假操纵信息流通防止义务，指定管理责任人，违者可处以刑罚或罚款。主张虚假操纵信息不仅侵害个人名誉和隐私，还威胁国民健康和社会安全。",
      "source": "联合新闻 (https://www.yna.co.kr/view/AKR20240612083100001)"
    },
    {
      "date": "2025-12",
      "topic": "虚假操纵信息根绝法",
      "stance_content": "发起'虚假操纵信息根绝法'，进一步强化对大型在线平台虚假信息流通的公共责任，要求赋予新闻流通平台与媒体同等的法律义务，并通过AI委员会等公共机构对平台的AI算法能力进行诊断和评估。",
      "source": "NamuWiki (https://namu.wiki/w/%ED%97%88%EC%9C%84%EC%A1%B0%EC%9E%91%EC%A0%95%EB%B3%B4%20%EA%B7%BC%EC%A0%88%EB%B2%95)"
    },
    {
      "date": "2025-10",
      "topic": "网络免费搭车（망 무임승차）防止",
      "stance_content": "发起法案要求海外大型平台和OTT等因国内产生的庞大流量而支付正当对价，违者处以罚款。主张海外大型平台不支付相应费用是破坏ICT生态良性循环结构的严重问题，德国等国际判例也承认支付义务。",
      "source": "电子新闻 (https://www.etnews.com/20251010000152)"
    },
    {
      "date": "2025-11",
      "topic": "门户新闻公共责任法",
      "stance_content": "发起'门户新闻公共责任法'，允许受害者通过言论仲裁委员会向门户请求防止损害扩大。要求提供争议报道的媒体向门户通报仲裁申请，门户须标明该报道已受理仲裁申请，门户本身也作为仲裁案件当事人纳入程序。",
      "source": "TruthGuardian (https://www.truthguardian.co.kr/news/article.html?no=26331)"
    }
  ],
