  "political_stances": [
    {
      "date": "2024-05",
      "topic": "劳动权益保护",
      "stance_content": "积极推动劳动权强化立法，主张建立劳动尊重社会。在第22届国会中以第1号法案发起劳动权强化五大连锁法案，涵盖最低工资法、劳动标准法等全面修订。",
      "source": "https://www.kyeonggi.com/article/20240530580184"
    },
    {
      "date": "2026-01",
      "topic": "实际劳动时间缩短",
      "stance_content": "认为仅靠每周52小时工作制不足以缩短实际劳动时间，主张通过国家与地方自治团体的综合计划、实态调查、支援与激励制度来系统推进实际劳动时间缩短。",
      "source": "https://www.kmaeil.com/news/articleView.html?idxno=627856"
    },
    {
      "date": "2024-09",
      "topic": "产业安全与灾害预防",
      "stance_content": "强调以劳动者生命与安全为优先的政策方向，推动更严格的产业灾害预防与劳动安全强化法规。发起的4项法案于2024年9月获国会全体会议通过，包括孕妇劳动时间缩短、产业安全保健法修订等。",
      "source": "http://www.ansanilbo1.com/news/articleView.html?idxno=15547"
    },
    {
      "date": "2026-01",
      "topic": "海外同胞权益",
      "stance_content": "发起国民健康保险法修订案，主张对在国内居住10年以上、持有F-4签证的65岁以上外国国籍同胞给予健康保险费减免，保障高龄同胞的医疗权益。",
      "source": "https://www.kmaeil.com/news/articleView.html?idxno=628314"
    },
    {
      "date": "2026-01",
      "topic": "生态保护",
      "stance_content": "发起保护区域基本法，主张在气候生态危机时代，生物多样性保全不是选择而是生存问题，呼吁建立跨部门的综合性保护区域管理体系。",
      "source": "https://www.greenkorea.org/activity/ecosystem-conservation/baekdudaegan-preservation/116152/"
    },
    {
      "date": "2025",
