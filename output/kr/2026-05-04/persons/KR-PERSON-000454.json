  "political_stances": [
    {
      "date": "2020-07",
      "topic": "房地产政策",
      "stance_content": "批评文在寅政府的房地产政策，认为多住宅者处置房产的要求违反市场经济原则和宪法保障的财产权，主张房地产政策应尊重市场规律。反对一刀切的增税和限贷措施。",
      "source": "国会演说 / 维基百科"
    },
    {
      "date": "2014",
      "topic": "公务员年金改革",
      "stance_content": "主导推动公务员年金改革，担任国会公务员年金改革特别委员会委员长，主张在保障公务员适当退休生活的同时，适应变化的社会环境改革年金制度，确保国家财政可持续性。",
      "source": "国会公务员年金改革特别委员会 / 新闻报道"
    },
    {
      "date": "2020-07",
      "topic": "脱核电政策",
      "stance_content": "反对文在寅政府的脱核电政策，称其为\"自残行为\"，主张维持和发展核电产业，强调核电的经济性和能源安全重要性。",
      "source": "韩国原子力产业会议报道"
    },
    {
      "date": "2020-05",
      "topic": "前总统特赦",
      "stance_content": "主张对朴槿惠和李明博两位前总统进行特赦，认为\"每位总统都无一例外地遭遇不幸的'总统悲剧'应该结束了\"，呼吁文在寅总统主动推进国民整合。",
      "source": "Facebook发帖 / 新闻报道"
    },
    {
      "date": "2020",
      "topic": "中道保守路线",
      "stance_content": "虽属保守阵营核心人物，但以温和理性风格著称，积极拓展中间路线。参加卢武铉前总统追悼式、演唱'为了劳动者的歌'（임을 위한 행진곡）、会见世越号遗属、主动接触湖南地区等行为体现了其中道保守立场。",
      "source": "联合新闻报道 / 纳木维基"
    }
