  "political_stances": [
    {
      "date": "2026-02",
      "topic": "房地产政策与民间住房供给",
      "stance_content": "主张通过重建、再开发等民间供给扩大方式解决住房问题，反对政府过度规制的房地产政策。就任国土交通委员会干事后表示将以规制改革为核心推动民间住房供给扩大，批评李在明政府的房地产政策使无住房平民的'购房梦想'更加遥远，指出'首次置业阶梯贷款'政策出台4个月后贷款件数同比减少57.9%。",
      "source": "首尔经济日报 (https://www.sedaily.com/article/20006343), Facebook"
    },
    {
      "date": "2025-01",
      "topic": "反对尹锡悦总统弹劾",
      "stance_content": "2024年12月7日尹锡悦总统弹劾案表决中缺席投票，被视为反对弹劾的立场。此后亦参与了国民力量党相关反对弹劾的党团活动。",
      "source": "NamuWiki (https://namu.wiki/w/%EC%9D%B4%EC%A2%85%EC%9A%B1(1965))"
    },
    {
      "date": "2025-12",
      "topic": "镇海地区发展与国家预算",
      "stance_content": "积极推动镇海新港建设及地区基础设施投资，为镇海争取2026年度国费预算5988亿韩元，其中414亿韩元为国会审议过程中新增反映。主张将镇海发展为'世界物流新中心地'，推动KTX镇海站建设等交通基础设施。",
      "source": "庆南日报 (https://www.gnnews.co.kr/news/articleView.html?idxno=625249)"
    },
    {
      "date": "2026-04",
      "topic": "住房认购制度改革",
      "stance_content": "发起《住房法》修正案，主张允许认购储蓄账户持有者在遭遇暂时性资金困难时无需解除整个账户即可部分提取已缴纳金额，避免居民因短期周转需要而丧失多年积累的认购资格。",
      "source": "庆南地方自治新闻 (http://www.klan.kr/news_gisa/gisa_view.htm?gisa_category=11020000&gisa_idx=276614&date_y=2026&date_m=04)"
    }
  ],
