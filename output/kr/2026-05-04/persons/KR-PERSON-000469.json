  "political_stances": [
    {
      "date": "2025-12",
      "topic": "学校供食法修订 — 学校非正规职劳动者权益保障",
      "stance_content": "主导推动学校供食法修订案，为学校供食室劳动者确立国家责任，设定适当人员编制标准，改善劳动环境与待遇。该法案于2025年12月通过国会教育委员会，被称为'让幽灵变成人'的历史性法案。",
      "source": "民Plus新闻 (https://www.minplusnews.com/news/articleView.html?idxno=17141)"
    },
    {
      "date": "2026-04",
      "topic": "能源公共化 — 韩国发电子社统合与可再生能源扩大",
      "stance_content": "主导发意'韩国发电子社法'，主张将五家发电子公司统合为单一发电子公司，扩大公共可再生能源投资，强化能源公共性、公正转换与能源主权。同时发意'公共可再生能源扩大法'，主张将可再生能源发电的公共化原则纳入法律。",
      "source": "能源新闻 (https://www.energy-news.co.kr/news/articleView.html?idxno=223819)"
    },
    {
      "date": "2026-04",
      "topic": "劳动市场二元结构改革 — 产业别交涉制度化",
      "stance_content": "发意劳动组合及劳动关系调停法修正案，主张超越企业别交涉框架、推动产业别交涉制度化，改善韩国劳动市场二元结构，强化劳动者的实质团结权。",
      "source": "PressDaily (https://pressdaily.co.kr/View.aspx?No=4050329)"
    },
    {
      "date": "2026-04",
      "topic": "AI数据中心振兴法反对 — 气候危机应对优先",
      "stance_content": "公开反对AI数据中心振兴特别法，批评该法为'AI数据中心特惠法'，认为在气候危机时代不顾电力与水资源准备不足而盲目扩大产业是'不负责任的法案'。",
      "source": "环境日报 (https://www.hkbs.co.kr/news/articleView.html?idxno=820474)"
    },
    {
      "date": "2025-05",
      "topic": "作业停止权实质保障 — 产业安全保健法修正",
      "stance_content": "发意产业安全保健法修正案，将作业停止权扩大至特殊雇佣·感情劳动者，增设气候危机相关（酷暑、暴雨、暴雪、强风）的作业停止标准，并保障劳动组合的作业停止权。",
      "source": "法律段 (https://www.lawsection.kr/news/articleView.html?idxno=310)"
    },
    {
      "date": "2025-01",
      "topic": "尹锡悦弹劾促请与戒严反对",
      "stance_content": "2024年12月尹锡悦宣布紧急戒严时突破封锁进入国会本会议厅参与戒严解除表决，此后在总统官邸前参加逮捕促请集会，并进行了十天绝食静坐促请宪法裁判所尽快裁定弹劾。期间参加全国农民会总联盟拖拉机行进时被警察导致负伤。",
      "source": "NamuWiki (https://namu.wiki/w/%EC%A0%95%ED%98%9C%EA%B2%BD)"
    }
  ],
