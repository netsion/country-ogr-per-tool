  "political_stances": [
    {
      "date": "2024-07",
      "topic": "劳动组合法修订",
      "stance_content": "作为国会环境劳动委员会干事，代表发起劳动组合法第2·3条修订案，主张将劳动基本权保护范围扩大至下级承包企业劳动者，使对劳动条件有实质影响力的原承包企业承担集体交涉义务。修订案被共同民主党采纳为党论。",
      "source": "http://www.gimponews.kr/news/articleView.html?idxno=1125"
    },
    {
      "date": "2025-07",
      "topic": "劳动者推定制与劳动基本法",
      "stance_content": "主张年内通过'劳动者推定制'立法，认为该制度可减少自营业者与劳动者之间的法律纠纷。同时推动'工作的人基本法'制定，强调'任何人按劳动获得报酬的社会才是先进民主社会'。",
      "source": "https://v.daum.net/v/20260430060143901"
    },
    {
      "date": "2025-06",
      "topic": "退休年龄延长与低出生率应对",
      "stance_content": "指出劳动面临新挑战，主张推进劳动组合法第2·3条修订、工作的人基本法制定、退休年龄延长等课题，强调新政府应与国会共同解决。",
      "source": "https://www.imaeil.com/page/view/2025062121031191478"
    },
    {
      "date": "2025-10",
      "topic": "AI转型与就业对策",
      "stance_content": "主张面对物理AI时代和产业结构重组加速，应预先制定政策应对，将就业危机转化为机遇。强调机器人税和基本收入的现实化需要社会大妥协。",
      "source": "https://www.dtoday.co.kr/news/articleView.html?idxno=764779"
    },
    {
      "date": "2025-10",
      "topic": "化学品安全管理",
      "stance_content": "在国政监察中披露6年间化学品皮肤腐蚀性事故达148件，要求政府加强化学物质安全管理制度。",
      "source": "https://www.waterjournal.co.kr/news/articleView.html?idxno=83233"
    },
    {
      "date": "2026-01",
      "topic": "气候部成立",
      "stance_content": "主张气候部成立应将'气候危机应对'与'产业转型'整合推进，作为电力产业和劳动领域专家积极推动气候能源政策立法。",
      "source": "https://www.electimes.com/news/articleView.html?idxno=363535"
    },
    {
      "date": "2026-02",
