  "political_stances": [
    {
      "date": "2025-02",
      "topic": "气候危机应对与环境保护",
      "stance_content": "积极推动气候危机适应立法，代表发议《气候危机适应及恢复力强化相关特别法》，定义气候危机弱势群体概念并制定保护对策。主张'应对日常化的气候危机、保护国民安全与生命是国家的责任'，推动绿色产品生产设施投资与购买的税制优惠政策。",
      "source": "庆北每日新闻 (https://www.ikld.kr/news/articleView.html?idxno=329406)"
    },
    {
      "date": "2025-07",
      "topic": "劳动政策与民生经济",
      "stance_content": "在环境劳动委员会积极推动大气环境管理强化、工资拖欠根绝、育儿休假延长等与国民生活直接相关的法案。关注劳动者权益保护，主张强化重大灾害事业场的安全管理，防止产业灾害。",
      "source": "iNews24 (https://www.inews24.com/view/1870244)"
    },
    {
      "date": "2026-02",
      "topic": "地区发展 — 庆山市物流枢纽化",
      "stance_content": "提出庆山至蔚山高速公路新建项目为未来核心课题，主张通过交通网络扩充实现物流革新，将庆山打造为岭南圈物流枢纽与产业中心。同时推进庆山公共废水处理设施地下化、下阳至南山国道替代绕行道路早期完工、进量与南川Hi-pass IC设置、大邱都市铁道1-2号线延长及循环线化等项目。",
      "source": "庆北日报 (https://www.kyongbuk.co.kr/news/articleView.html?idxno=4063299)"
    },
    {
      "date": "2026-02",
      "topic": "宪政民主与司法独立",
      "stance_content": "批评在野党强行处理检察官法官'法歪曲罪'法案为'动摇司法独立的立法暴走'，在国会本会议凌晨冗长辩论（filibuster）后发表批评声明，主张维护司法独立与程序正当性。",
      "source": "iNews24 (https://www.inews24.com/view/1943553)"
    }
  ],
