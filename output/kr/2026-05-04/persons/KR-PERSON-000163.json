  "political_stances": [
    {
      "date": "2022",
      "topic": "财政健全性",
      "stance_content": "强调财政纪律和健全性，主张保守的财政政策。担任经济副总理期间推行财政紧缩，坚持'选择与集中'原则，反对过度扩张性财政支出。",
      "source": "Korea JoongAng Daily (2023), 韩国国会记录"
    },
    {
      "date": "2014",
      "topic": "规制改革",
      "stance_content": "积极推动经济规制改革，倡导'规制断头台（규제기요틴）'式高强度改革方式，主张消除阻碍市场效率和经济增长的不合理规制。",
      "source": "韩国维基百科, 2014年规制断头台民官合同会议发言"
    },
    {
      "date": "2012",
      "topic": "市场经济与自由竞争",
      "stance_content": "坚定支持市场经济和自由竞争体制，强调政府与民间的适当角色分配，主张政府应为市场创造良好环境而非过度干预。",
      "source": "2012年全球绿色增长论坛发言"
    },
    {
      "date": "2026",
      "topic": "亲保守·亲企业立场",
      "stance_content": "作为国民力量党核心成员，持鲜明的保守亲企业立场。强调保守权力的经济能力，主张通过培育尖端产业、减少规制来激发经济活力，反对进步派的增税和扩大政府支出政策。",
      "source": "Chosun.com (2026/04/27), 2026年大邱市长竞选发言"
    }
  ],
