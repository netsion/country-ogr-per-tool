  "political_stances": [
    {
      "date": "2025-05",
      "topic": "房地产政策 - 再建重建活化",
      "stance_content": "主张房地产政策应具有可预测性和一贯性。代表发起《再建重建促进特例法》，要求废除重建超额利润回收制（재초환）和综合不动产税（종부세），降低公共贡献比率，推动分堂等一期新城的快速再建重建。",
      "source": "Newsis (https://www.newsis.com/view/NISX20250522_0003185290)"
    },
    {
      "date": "2025-07",
      "topic": "数字资产与稳定币立法",
      "stance_content": "代表发起韩元稳定币立法法案，主张建立用户安全保障机制，排除美国 Genius 法案中'利息支付禁止'条款，为韩元稳定币使用设置激励措施，推动韩国数字资产制度化。",
      "source": "首尔新闻 (https://www.seoul.co.kr/news/politics/2025/07/28/20250728500109)"
    },
    {
      "date": "2026-02",
      "topic": "税务政策 - 反对糖税",
      "stance_content": "严厉批评民主党推行的糖分征税是'伪装的增税'，认为征税对象是国民的生活习惯而非公共卫生问题，强调应通过市场自律而非增税解决健康问题。",
      "source": "朝鲜日报英文版 (https://www.chosun.com/english/national-en/2026/02/03/NCPELNQ6QBB6DO4T2EBFLEOTCA/)"
    },
    {
      "date": "2025-10",
      "topic": "消费者保护 - 购物安全三大法",
      "stance_content": "推动所谓'三大购物防害法'立法，旨在保护消费者在在线购物中的权益，包括加强电商平台的透明度和消费者退款权利。",
      "source": "每日经济 (https://www.mk.co.kr/en/columnists/11442868)"
    }
