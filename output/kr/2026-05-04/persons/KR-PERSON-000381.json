  "political_stances": [
    {
      "date": "2022",
      "topic": "司法改革与法治",
      "stance_content": "作为检察官出身的政治人物，金度邑长期关注司法独立和法治建设。在法制司法委员会担任委员及委员长期间，积极推动司法制度改革，反对执政党操控司法机构，曾担任自由韩国党'文在寅政权司法掌控阻止及司法部独立守护特别委员会委员长'。",
      "source": "ko.wikipedia.org/wiki/김도읍"
    },
    {
      "date": "2024",
      "topic": "釜山地方发展",
      "stance_content": "长期致力于釜山江西区及西釜山地区的发展，推动西釜山圈城市铁道早期建设，积极推动海洋水产部及相关机构迁至釜山江西区，主张釜山作为海洋首都的定位，推动地方均衡发展。",
      "source": "www.kimdoeup.com"
    },
    {
      "date": "2019",
      "topic": "自由市场经济",
      "stance_content": "作为自由经济论坛组成议员，主张自由市场经济体制，反对过度政府干预。2019年获自由经济立法奖，多次推动减轻企业负担、促进市场活力的立法。",
      "source": "ko.wikipedia.org/wiki/김도읍"
    },
    {
      "date": "2020",
      "topic": "反腐败与公职纪律",
      "stance_content": "以检察官出身的严格标准要求公职人员，曾积极参与调查国家情报院舆论操纵事件、民间人非法搜查等重大案件。在第21届国会担任法制司法委员会委员长期间主导多项反腐立法。曾就曹国法务部长候选人争议发挥重要监督角色。",
      "source": "namu.wiki/w/김도읍"
    }
  ],
