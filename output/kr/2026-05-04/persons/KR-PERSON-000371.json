    },
    {
      "date": "2022",
      "topic": "KBS收视费制度改革",
      "stance_content": "担任总统室市民社会首席秘书官期间推动KBS电视收视费与电费分离征收制度改革，反映国民对公共广播公平性和竞争力的关切。国民提议投票中97%赞成改革。",
      "source": "https://www.ytn.co.kr/_ln/0101_202411140829335242"
    },
    {
      "date": "2024",
      "topic": "地方均衡发展",
      "stance_content": "担任第2期国会地区均衡发展论坛共同代表，积极推进忠清南道等地区的基础设施建设和区域经济均衡发展，主张世宗国会议事堂建设。",
      "source": "https://ko.wikipedia.org/wiki/%EA%B0%95%EC%8A%B9%EA%B7%9C"
    },
    {
      "date": "2025-02",
      "topic": "反对弹劾尹锡悦",
      "stance_content": "2025年在宪法法院前参加一人示威，反对弹劾总统尹锡悦，强调应尊重民主程序和宪法秩序。认为弹劾案应尊重党指导层的判断。",
      "source": "https://www.ytn.co.kr/_ln/0101_202502190739285803"
    }
