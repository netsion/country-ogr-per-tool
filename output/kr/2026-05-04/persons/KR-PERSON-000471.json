  "major_achievements": [
    {
      "title": "主导2024年12月戒严解除与弹劾案",
      "achievement": "2024年12月4日凌晨，尹锡悦总统宣布紧急戒严后，禹元植翻越国会围墙进入议事堂，紧急召集190名议员以全票通过戒严解除决议案。随后于12月14日主持尹锡悦总统弹劾案表决，以204票赞成通过弹劾。因其沉着应对被国际媒体称为'政治雷神'，盖洛普民调显示其信任度达56%，成为韩国最受信赖的政治人物。",
      "date": "2024-12-04",
      "organization": "大韩民国国会"
    },
    {
      "title": "创立'乙之路委员会'",
      "achievement": "2013年创立'乙之路委员会'(을지로위원회)，旨在保护中小企业、个体经营者和非正规职劳动者免受大企业'甲方霸道'行为侵害。该委员会成功调解了南洋乳业欺压代理店、三星半导体白血病受害者赔偿等多起重大劳资纠纷，成为文在寅总统第一号经济民主化承诺的来源。",
      "date": "2013-05",
      "organization": "乙之路委员会"
    },
