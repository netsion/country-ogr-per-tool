  "political_stances": [
    {
      "date": "2024-09-30",
      "topic": "医科大学增员与医疗改革",
      "stance_content": "主张医科大学增员与医疗改革是硬币的两面，提出《保健医疗人力支援法》修正案和《高等教育法》修正案，要求建立科学依据和社会共识基础上的医疗人力供需推算委员会制度，以确定2026学年度医大定员调整方案。",
      "source": "https://www.dailymedi.com/news/news_view.php?wr_id=916834"
    },
    {
      "date": "2024-11-15",
      "topic": "公共医疗强化",
      "stance_content": "主导发起了‘公共医疗强化四法‘（公共保健医疗法、农村渔村保健医疗特别法、地方医疗院法、地方税特例限制法修正案），旨在全面改革韩国公共医疗体系，加强地方医疗基础设施。",
      "source": "http://www.khanews.com/news/articleView.html?idxno=231042"
    },
    {
      "date": "2025-04-27",
      "topic": "必需医疗与无政府式医疗体系转型",
      "stance_content": "在江原原州现场讨论会上主张，韩国应从当前‘无政府式医疗体系‘转型为有计划、有协调的必需医疗提供体系，强调地区完结型必需医疗供给与地区间医疗差距消除。",
      "source": "https://www.medifonews.com/news/article.html?no=213207"
    },
    {
      "date": "2024-07-11",
      "topic": "必需医疗强化",
      "stance_content": "主导发起‘必需医疗强化三法‘（必需医疗强化特别法、国家财政法、保健医疗基本法的制定和修正案），设立必需医疗水费和必需医疗基金，建立保健医疗资源治理机制，解决首都圈患者集中和地区医疗差距问题。",
      "source": "https://www.monews.co.kr/news/articleView.html?idxno=333269"
    },
    {
      "date": "2025-01-13",
      "topic": "医疗改革与尹锡悦政府批判",
      "stance_content": "在记者会上表示‘尹锡悦式医疗改革已随弹劾一起被审判‘，主张激活保健医疗人力政策审议委员会，强化其决议权并要求决议事项必须向国会福利委报告，以避免医大增员方面的消耗性冲突。",
      "source": "https://www.etnews.com/20250113000388"
    },
    {
      "date": "2024-06-28",
      "topic": "保健医疗人力法案",
      "stance_content": "就任后第一号法案提出《保健医疗人力支援法》修正案，要求设立调整医疗各职业间业务的委员会，主张政府应就医疗大增员与医师协会进行透明公开的协商，反对政府单方面决策。",
      "source": "https://www.mt.co.kr/thebio/2024/06/28/2024062816583410253"
    }
  ],
