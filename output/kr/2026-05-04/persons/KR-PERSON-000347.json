  "political_stances": [
    {
      "date": "2018",
      "topic": "就业政策与产业振兴",
      "stance_content": "强力推动就业创造政策。在文在寅政府担任就业首席秘书官期间，主导了「光州型就业」和「龟尾型就业」模式，通过与地方政府、工会、现代汽车和LG化学等企业协调，以降低工资换取社会保障和福利的方式保障制造业岗位。还推动「第二风投热潮」和个体经营对策等政策。",
      "source": "https://ko.wikipedia.org/wiki/%EC%A0%95%ED%83%9C%ED%98%B8_(1963%EB%85%84)"
    },
    {
      "date": "2020",
      "topic": "冠岳区创业生态圈建设",
      "stance_content": "积极推动冠岳S谷（관악S밸리）建设，将其打造为韩国版硅谷。推动新林创业谷（신림창업밸리）Season 1和Season 2计划，吸引KT、KB金融集团等大企业参与，构建风险创业生态系统，推动冠岳区被指定为「风险企业培育促进地区」，以扩大创业基础设施、创造就业和激活地区经济。",
      "source": "https://www.gtimes.co.kr/news/articleView.html?idxno=14206"
    },
    {
      "date": "2024",
      "topic": "社会经济与包容性增长",
      "stance_content": "主导发起《社会经济基本法》，构建社会经济成长促进的综合系统性推进体系，通过金融和政策支持实现可持续增长基础。关注地区循环经济和缓解两极分化问题，致力于缩小贫富差距。",
      "source": "https://www.youcandonews.com/news/articleView.html?idxno=9978"
    },
    {
      "date": "2024",
      "topic": "对尹锡悦政府的批评",
      "stance_content": "严厉批评尹锡悦政府的国政运营，称其具有「时代逆行性国政运营哲学」和「政策失踪」问题。主张应通过国会调查查明尹锡悦政权政治检察捏造起诉疑云真相。",
      "source": "https://news.nate.com/view/20240616n02890"
    },
    {
      "date": "2024",
      "topic": "社会福利与孤立问题",
      "stance_content": "主张对全体国民进行孤立和隐居状态的定期调查，关注社会弱势群体福祉。参考英国2018年设立「孤独部长」的先例，推动韩国在国家层面对社会孤立问题的应对。",
      "source": "https://hrcopinion.co.kr/en/article?board_name=board_5_1"
    }
  ],
