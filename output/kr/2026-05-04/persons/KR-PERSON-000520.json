  "political_stances": [
    {
      "date": "2026-01-09",
      "topic": "反歧视立法",
      "stance_content": "作为第22届国会首次《反歧视法》（차별금지법）的领衔提案人，主张在性别、残疾、病史、性取向、宗教、社会身份等所有领域禁止无合理依据的歧视，提出将保护范围从'雇佣合同'扩大至'劳务提供合同'以覆盖平台劳动者，并引入国家人权委员会直接起诉制度和集体诉讼制度等新机制。",
      "source": "https://www.ntoday.co.kr/news/articleView.html?idxno=124092"
    },
    {
      "date": "2025-06",
      "topic": "青年劳动权益",
      "stance_content": "主张废除包干工资制（포괄임금제），推动新设'青年转职准备津贴'（청년이직준비급여），使青年在自愿离职寻找更好工作条件时也能获得失业保障。认为现行劳动法无法反映当代青年频繁转职的现实，反而将青年推向制度死角。",
      "source": "https://www.womennews.co.kr/news/curationView.html?idxno=263891"
    },
    {
      "date": "2025-06",
      "topic": "照料社会与基本权利",
      "stance_content": "主张推动《照料基本法》（돌봄기본법）和《照料劳动者法》（돌봄노동자법），认为面对人口悬崖与气候危机等个人无法承受的冲击，必须在全社会层面扩大照料覆盖范围，使照料成为时代价值。",
      "source": "https://www.womennews.co.kr/news/curationView.html?idxno=263891"
    },
    {
      "date": "2025-06",
      "topic": "内乱清算与社会大改革",
      "stance_content": "将'内乱清算与社会大改革'定位为核心政治使命，认为尹锡悦政权戒严令事件后国民用选票否决了否决权国会，新国会应以'内乱克服和社会大改革'为时代课题，集中推进恢复普通民众权利和基本保障。",
      "source": "https://www.labortoday.co.kr/news/articleView.html?idxno=228473"
    },
    {
      "date": "2022",
      "topic": "政治犯赦免",
      "stance_content": "2022年以区议员预备候选人身分主张恢复进步政治需要'治愈伤痕'，呼吁文在寅政府在任期内赦免恢复前议员李石基的公民权，并推动十万人联名运动。",
      "source": "https://namu.wiki/w/%EC%86%90%EC%86%94"
    }
  ],
