  "political_stances": [
    {
      "date": "2025-08",
      "topic": "舆论改革与广播独立性",
      "stance_content": "担任共同民主党舆论改革特别委员会委员长，主导推进\"广播三法\"修订，主张确保公营广播的独立性、改革广播通信委员会组织结构、将科学技术情报通信部的付费广播政策职能移交通信委员会。长期参与\"反朝鲜日报运动\"，主张打破保守媒体垄断。",
      "source": "韩语维基百科 / 新闻报道"
    },
    {
      "date": "2025-10",
      "topic": "虚假信息治理与表达自由",
      "stance_content": "代表发起《信息通信网法》修正案（虚假编造信息根绝法），规定国家对虚假信息的流通进行禁止，并允许对虚假编造信息处以惩罚性损害赔偿。该法案引发舆论争议，被批评为可能威胁表达自由和宪法权利。",
      "source": "媒体改革 / 京乡新闻"
    },
    {
      "date": "2024",
      "topic": "女性权益与育儿政策",
      "stance_content": "长期关注自然健康育儿和女性权益议题。创立自然健康育儿团体'水수팥떡아이사랑모임'并运营15年，著有《拉金黄色便便的婴儿》等多部育儿书籍，倡导自然分娩和健康育儿理念。",
      "source": "韩语维基百科 / 个人著作"
    },
    {
      "date": "2016-02",
      "topic": "反恐法反对（ filibuster）",
      "stance_content": "参与反对反恐法的filibuster（无限制演讲），连续发言5小时21分钟，批评反恐法侵犯公民隐私权和基本自由。",
      "source": "新闻报道 / 韩语维基百科"
    },
    {
      "date": "2024-03",
      "topic": "政权审判论",
      "stance_content": "在第22届总选期间主张'政权审判'，呼吁选民通过投票对执政党进行审判，以恢复民主秩序。",
      "source": "新闻1报道"
    }
  ],
