  "political_stances": [
    {
      "date": "2025-06",
      "topic": "行政首都世宗完成",
      "stance_content": "作为'行政首都建立特别措施法案'的领衔提案人，主张通过立法明确行政首都世宗的法律地位，将总统办公室和国会主议事堂迁移至世宗，实现立法、司法、行政三权完备的完整行政首都。认为'行政首都完成不仅是世宗市的发展问题，更是韩国解决首都圈过密化、提高行政效率、实现国家均衡发展的核心课题'。",
      "source": "https://www.dailyt.co.kr/newsView/dlt202506250019"
    },
    {
      "date": "2025-12",
      "topic": "世宗城市定位与未来发展",
      "stance_content": "在2026年新年记者会上表示'世宗不再是谈论可能性的城市，而是已经进入国家中心完成阶段的城市'，强调将继续推动行政首都世宗的实质化进程。提出将世宗打造为韩国经济和行政的'一中心'战略构想。",
      "source": "https://www.newsclick.kr/news/articleView.html?idxno=2468"
    },
    {
      "date": "2026-03",
      "topic": "国会世宗议事堂建设",
      "stance_content": "作为国会世宗议事堂建立委员，强调'国会世宗议事堂是行政首都的象征空间，应通过国际公开征集设计，建成承载韩国未来的世界级空间'。推动议事堂建设进入正式设计阶段，2026年5月中旬公布获奖方案。",
      "source": "https://www.e-sejong.co.kr/news/articleView.html?idxno=13291"
    },
    {
      "date": "2026-04",
      "topic": "行政首都特别法推进优先于修宪",
      "stance_content": "认为'行政首都特别法的处理比修宪中明文规定行政首都更为重要和紧迫'，强调应优先通过特别法确立制度基础，而非等待社会共识形成后再修宪。",
      "source": "https://www.dtnews24.com/news/articleView.html?idxno=809187"
    },
