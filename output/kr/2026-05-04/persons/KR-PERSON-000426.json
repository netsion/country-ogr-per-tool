  "political_stances": [
    {
      "date": "2024-07",
      "topic": "核潜力政策",
      "stance_content": "主张韩国应效仿日本，拥有核燃料循环能力（核潜力），包括铀浓缩和钚再处理能力，以在不拥核的前提下形成有效威慑力。发起国会木槿花论坛推动原子力振兴法修正案。",
      "source": "国会木槿花论坛政策讨论会"
    },
    {
      "date": "2024-11",
      "topic": "国防产业振兴",
      "stance_content": "推动防务产业改革，主张允许防务企业直接持有和出口防务物资，减少对政府所有样品和军备的依赖，提升韩国武器出口竞争力。",
      "source": "防务事业法修正案提案"
    },
    {
      "date": "2025-02",
      "topic": "对朝强硬安保",
      "stance_content": "坚持对朝鲜军事威胁的强硬立场，亲自赴乌克兰会见被俘朝鲜军人并公开录音，揭露朝鲜在俄罗斯战场的行为及对韩国地形的模拟训练。",
      "source": "乌克兰访问及国会质询"
    },
    {
      "date": "2004",
      "topic": "核潜艇拥有",
      "stance_content": "长期主张韩国应拥有核动力潜艇，早在记者时期即多次报道相关议题，2025年特朗普政府事实上批准后其主张再次受到关注。",
      "source": "朝鲜日报报道及国会活动"
    }
