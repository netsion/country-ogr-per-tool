  "political_stances": [
    {
      "topic": "废矿区产业转型",
      "stance_content": "主导推动将'废矿地域'正名为'煤炭产业转换地域'的立法，认为矿区为国家工业化做出历史性贡献，应通过制度性支持促进其向未来新能源产业中心转型，消除'废矿'带来的负面认知。",
      "date": "2025-10",
      "source": "https://www.kado.net/news/articleView.html?idxno=2041805"
    },
    {
      "topic": "亲尹锡悦立场",
      "stance_content": "被视为国民力量党内亲尹（尹锡悦）派核心人物（'尹核管'），在尹锡悦竞选总统期间担任国民阵营组织总括本部长及当选人总括辅佐役，支持尹锡悦政府的各项政策方向。",
      "date": "2022-03",
      "source": "https://www.yna.co.kr/view/AKR20240627064000001"
    },
    {
      "topic": "能源与半导体产业政策",
      "stance_content": "作为国会产业通商资源中小风险企业委员会委员长，积极推动半导体产业振兴法、能源特别委员会活动，关注韩国半导体供应链安全与电池产业发展。",
      "date": "2024-06",
      "source": "https://ampos.nanet.go.kr/activityCongressDetail.do?congress_no=G1899580"
    },
    {
      "topic": "江原地区发展",
      "stance_content": "长期致力于江原道地方发展，推动江原特别自治道法修订、矿区铁路及交通改善，反对忽视江原地区的中央政策，主张加大投资以促进区域均衡发展。",
      "date": "2022-05",
      "source": "https://www.g1tv.co.kr/news/?mid=1_10&newsid=308779"
    }
  ],
