  "political_stances": [
    {
      "date": "2020",
      "topic": "司法改革",
      "stance_content": "积极推动司法改革，主张建立以国民为中心的司法制度。提出'先进司法'（以国民人权为最优先的搜查和裁判）、'责任司法'（对失职法官和检察官追究责任）、'民主司法'（扩大一般市民在司法过程中的参与和监督）三大理念。代表发起了律师法修订案（强化不合格检察官和法官的律师注册审查）、法院组织法修订案（扩大国民参与法官人事委员会）、检察厅法修订案等核心司法改革法案。",
      "source": "https://peoplemoa.co.kr/entry/%EC%B5%9C%EA%B8%B0%EC%83%81-%EC%9D%98%EC%9B%90-%EA%B3%A0%ED%96%A5-%EC%9E%AC%EC%82%B0-%EB%82%98%EC%9D%B4-%ED%95%99%EB%A0%A5-%EB%B6%80%EC%9D%B8-%EC%9E%90%EB%85%80-%ED%94%84%EB%A1%9C%ED%95%84"
    },
    {
      "date": "2026-03",
      "topic": "检察改革",
      "stance_content": "强烈支持检察改革，主张分离搜查权与起诉权。支持设立公搜处，推动公诉厅法通过。反对赋予公诉厅检察官补充搜查权，坚持搜查与起诉分离原则不可动摇。担任民主党检察独裁政治弹压对策委员会委员、政治检察捏造起诉应对TF共同副团长等职务，持续推动检察体系改革。",
      "source": "https://biz.chosun.com/policy/politics/assembly/2026/03/20/FVB7MEBEVVA3TJZ3M6QCJNAAAM/"
    },
    {
      "date": "2023-03",
      "topic": "大法院长任命制度改革",
      "stance_content": "主张改革大法院长任命制度，限制总统对大法院长的任命权。2023年3月代表发起法院组织法修订案，提议设立'大法院长候补推荐委员会'，由11名委员组成（含非法律界人士5名，其中女性2名），需三分之二以上赞成才能推荐候选大法院长，旨在减少大法院长任命中的政治争议。",
      "source": "https://www.newdaily.co.kr/site/data/html/2023/03/29/2023032900096.html"
    },
    {
      "date": "2023",
      "topic": "民生经济",
      "stance_content": "关注民生经济议题，提出'36.5度！为庶民的温暖立法'口号，推动供暖费分期偿还法等民生法案。在第22届国会中隶属企划财政委员会，积极参与财政经济政策制定。担任民主党物价对策TF干事、税制改编特别委员会委员等职务，致力于减轻民众经济负担。",
      "source": "https://www.youtube.com/watch?v=bA0H9U2_9MU"
    }
  ],
