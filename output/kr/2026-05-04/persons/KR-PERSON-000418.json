  "political_stances": [
    {
      "topic": "国防自主与国防半导体",
      "stance_content": "强调国防半导体99%依赖海外的危险性，主导制定《国防半导体培育及支援相关法律》，主张实现国防武器体系核心技术自立，将国防半导体自主化视为国家安全的关键议题。",
      "source": "https://www.news-home.co.kr/news/articleView.html?idxno=57082"
    },
    {
      "topic": "国防政策与军队福利",
      "stance_content": "作为国防委员会委员长，推动军人福利和服役环境改善，强调国防事务超越朝野党派分歧，致力于加强防卫事业推进委员会的政治中立性和专业性。",
      "source": "https://www.cctoday.co.kr/news/articleView.html?idxno=2199379"
    },
    {
      "topic": "国防改革与韩美同盟",
      "stance_content": "关注战时作战指挥权转移问题，批评朝鲜·中国·俄罗斯所期望的作战指挥权转移是危险的赌博，主张在新政府国防政策中审慎评估韩美同盟现代化方向。",
      "source": "https://www.ngonews.kr/news/articleView.html?idxno=216324"
    },
    {
      "topic": "地方经济发展",
      "stance_content": "为瑞山地区企业争取电费减免，推动补充预算案反映地方产业危机应对措施，积极为选区经济发展争取政策支持。",
      "source": "https://m.joongdo.co.kr/view.php?key=20260402010000796"
    }
  ],
