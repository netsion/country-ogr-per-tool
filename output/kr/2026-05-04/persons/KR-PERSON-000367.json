  "political_stances": [
    {
      "date": "2024-06",
      "topic": "国防安全与自主国防",
      "stance_content": "强调自主国防建设，推动国防核心材料（如纺织材料）国产化，减少对海外进口依赖。关注朝鲜军事威胁应对，反对仓促恢复9·19军事协议。主张加强国防预算和军队现代化建设。指出PBO·PBI等高性能纤维的军方自给率接近0%，国产化是选择而非选项。",
      "source": "国会国防委员会活动及国防纺织材料国产化论坛"
    },
    {
      "date": "2024-06",
      "topic": "地域均衡发展",
      "stance_content": "作为大邱出身的国会议员，致力于推动大邱庆北地区基础设施建设，特别是大邱庆北新机场的统合迁移项目和空军第11战斗机联队的迁移。关注消除地区间发展不平衡，担任国会地域均衡发展论坛共同代表，主张缓解60余年战斗机噪音困扰。",
      "source": "选举承诺及国会活动"
    },
    {
      "date": "2025-01",
      "topic": "保守派经济政策与民生经济",
      "stance_content": "作为国民力量党核心成员，主张保守派经济政策，关注民生经济稳定。反对民主党推进的特别检察官法等所谓'政治特检'，批评其浪费国民税金154亿韩元。担任中产层·庶民经济委员长，关注物价高企等'三高危机'下的经济民生问题。",
      "source": "Facebook发言及党内活动"
    }
  ],
