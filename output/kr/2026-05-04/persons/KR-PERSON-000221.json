  "political_stances": [
    {
      "date": "2025-09",
      "topic": "YouTube权力与媒体改革",
      "stance_content": "公开批评亲执政党YouTuber（如金于准的'谦虚是很难的News工场'）对民主党内政的过度影响，称'如果YouTube广播是权力者，我不打算低头做政治'，主张政治不应被特定媒体人左右，呼吁警惕YouTube权力对政党事务和公推过程的介入。",
      "source": "https://www.seoul.co.kr/news/politics/2025/09/18/20250918002001"
    },
    {
      "date": "2026-03",
      "topic": "卢武铉精神与政治利用",
      "stance_content": "批评部分政治人物将已故卢武铉前总统'召唤'用于政治利益的行为，指出'现在民主党内卢武铉的政治连痕迹都不剩'，反对以检察改革为名消费卢武铉之死，主张真正继承卢武铉精神应体现在实际政治行动中。",
      "source": "https://www.hani.co.kr/arti/politics/politics_general/1250046.html"
    },
    {
      "date": "2024-11",
      "topic": "电力费率改革",
      "stance_content": "作为产业通商资源中小风险企业委员会委员，代表发起了《电气事业法部分修正法律案》，主张将电费核准的核心标准从施行令和告示层面提升至法律层面直接规定，以纠正垄断企业韩国电力公社的用途差别费率制和住宅用累进制问题，增强国会立法权。",
      "source": "https://www.energydaily.co.kr/news/articleView.html?idxno=162242"
    },
    {
      "date": "2025-12",
      "topic": "光化门集会受害居民支援",
      "stance_content": "针对2024年12月戒严事件后至2025年4月间光化门广场长期集会示威对钟路区居民和商户造成的损害，代表发起了《钟路区光化门广场一带集会示威受害居民支援特别法》，主张国家应承担受害居民的生活安定支援和损失补偿责任。",
      "source": "https://www.mk.co.kr/news/politics/11588675"
    },
    {
      "date": "2026-04",
      "topic": "宪法之日与宪政价值",
      "stance_content": "代表发起了《关于国庆日的法律部分修正案》，将制宪节更名为'宪法之日'，在经历12·3戒严事件后，旨在提高国民对宪法价值和宪法破坏危险性的关注，使国庆日名称更易于理解。",
      "source": "https://www.ikbn.news/news/article.html?no=196136"
    },
    {
      "date": "2026-04",
      "topic": "法扭曲罪争议",
      "stance_content": "对执政党推进的'法扭曲罪'立法表示异议，认为该立法可能威胁司法独立和法治主义，强调法律不应成为政治斗争的工具。",
      "source": "https://news.kbs.co.kr/news/view.do?ncd=8525256"
    }
