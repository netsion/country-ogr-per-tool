  "major_achievements": [
    {
      "date": "2020-06-30",
      "achievement": "作为第21届国会1号法案，代表发议《造船产业支援特别法制定案》，内容涵盖造船产业振兴综合对策制定、亲环境及智能自律航行船舶等新一代船舶技术开发支援、专业人力中长期供需方案、税制优惠及金融支援扩大、以及劳动时间制度弹性化等。",
      "organization": "国会（국회）"
    },
    {
      "date": "2025-01",
      "achievement": "推动巨加大桥通行费减免取得成果，自2025年起新年开始周末及公休日乘用车通行费降低20%（从10000韩元降至8000韩元），这是12年来首次实现通行费降低。后又于2026年4月代表发议《租税特例限制法》修正案，通过税制激励引导企业自愿减免通行费负担。",
      "organization": "国会（국회）"
    },
    {
      "date": "2020-04-15",
      "achievement": "在第21届国会议员选举中以50.89%得票率当选（庆南巨济市，未来统合党），2024年4月10日又以51.23%得票率连任成功（国民力量党），成为巨济市历史上首位连续当选的国会议员。",
      "organization": "国民力量党（국민의힘）"
    },
    {
      "date": "2022-03",
      "achievement": "担任第20届总统职务接管委员会行政室长兼总统就任准备委员会委员，负责尹锡悦政府交接期的行政事务工作。",
      "organization": "第20届总统职务接管委员会"
    }
  ],
  "political_stances": [
    {
      "date": "2025-03",
      "topic": "造船产业振兴",
      "stance_content": "代表发议《造船产业支援特别法制定案》，主张造船业不仅是单纯的制造业，而是涵盖出口、就业、通商、国家安全的核心产业，要求政府从制度层面提供全面支援，包括新一代船舶技术开发、专业人力培养、税制和金融优惠、以及劳动时间弹性化等。",
      "source": "首尔经济 (https://www.sedaily.com/NewsView/2GQDD3MH91)"
    },
    {
      "date": "2026-04",
      "topic": "巨加大桥通行费减免",
      "stance_content": "代表发议《租税特例限制法》修正案，指出巨加大桥通行费为乘用车标准往返2万韩元，为全国收费公路中最高水平，构成进入巨济的实际壁垒。主张通过税制激励（企业为访客承担通行费时给予30%法人税减免）改善巨济地区可达性，激活企业革新公园等开发项目。",
      "source": "NewsPI M (https://www.newspim.com/news/view/20260420000867)"
    },
    {
      "date": "2024",
      "topic": "保守派亲企业立场",
      "stance_content": "作为国民力量党核心成员，持亲企业、放宽管制立场，主张通过灵活劳动制度提升造船等制造业竞争力，反对过度规管。在国会产业通商资源中小风险企业委员会积极推动产业支援立法。",
      "source": "Pollite (https://www.pollite.kr/member/%EC%84%9C%EC%9D%BC%EC%A4%80)"
    },
    {
      "date": "2024",
      "topic": "地区均衡发展",
      "stance_content": "长期关注巨济地区交通基础设施改善、沙谷国家产业园持续推进、旅游业振兴等议题，主张将巨济发展为K造船、观光产业与物流、休养相结合的未来产业城市。",
      "source": "巨济新闻 (https://www.geojenews.co.kr/news/articleView.html?idxno=80834)"
    }
  ],
