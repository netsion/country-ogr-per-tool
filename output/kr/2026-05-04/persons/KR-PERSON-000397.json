  "political_stances": [
    {
      "date": "2024-06",
      "topic": "昌原防卫·原子力融合国家产业园早期建设",
      "stance_content": "将'昌原防卫·原子力融合产业园区迅速推进法'（产业选址及开发相关法律修正案）作为第22届国会1号法案提出，主张通过特别程序加速国家产业园区的选址和开发，推动昌原防卫·原子力融合国家产业园早期建成。持续在国会国土交通委员会上敦促国土部和LH加快进度。",
      "source": "韩国经济 (https://m.sedaily.com/amparticle/13904104)"
    },
    {
      "date": "2024-06",
      "topic": "防产零部件研究院设立立法",
      "stance_content": "代表发起防卫产业发展法修正案，为防产零部件研究院的设立提供法律依据，规定研究院的业务和功能，并赋予国有财产使用的特别规定，旨在为K-防产全球竞争力奠定基础。",
      "source": "庆南日报 (http://www.gnnews.co.kr/news/articleView.html?idxno=556225)"
    },
    {
      "date": "2026-04",
      "topic": "国家产业园建设加速与地方经济振兴",
      "stance_content": "在国会国土交通委员会机关业务报告中强烈质询国土部和LH关于新设国家产业园推进停滞的问题，强调15处新设国家产业园的迅速建设是确保未来竞争力的最紧迫课题，批评相关机构不作为导致昌原防卫·原子力国家产业园推进事实上停滞不前。",
      "source": "联合新闻 (https://www.yna.co.kr/view/AKR20260402056200052)"
    },
    {
      "date": "2024-08",
      "topic": "昌原产业园数字工厂转型",
      "stance_content": "主张推动昌原产业园向'数字工厂'转型，提升传统制造业竞争力，同时强调防卫产业和原子力产业的融合发展是昌原和庆南地区未来经济的核心增长引擎。",
      "source": "庆南新闻 (https://knnews.co.kr/news/articleView.php?idxno=1438596)"
    }
  ],
