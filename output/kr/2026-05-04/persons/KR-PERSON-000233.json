  "political_stances": [
    {
      "date": "2024-05",
      "topic": "特例市制度完善",
      "stance_content": "主张高阳特例市应获得与广域自治团体相当的实际权限，包括高层建筑许可权、老旧公共住宅改造规划权等，推动《特例市支援特别法》作为第22代国会1号法案提出并促成通过。",
      "source": "https://www.mygoyang.com/news/articleView.html?idxno=88269"
    },
    {
      "date": "2025-09",
      "topic": "游戏产业规制改革",
      "stance_content": "反对将游戏过度视为规制对象，主张将游戏视为重要的K-内容出口产业予以支持。认为应禁止类似赌博的Complete Gacha机制，但支持将开发资源投入创作性内容，推进游戏产业的健康发展。",
      "source": "https://www.ohmynews.com/NWS_Web/View/at_pg.aspx?CNTN_CD=A0003169501"
    },
    {
      "date": "2025-09",
      "topic": "宪法修改程序制度化",
      "stance_content": "发起《宪法修改程序法》，主张将修宪从巨大事件转变为每4年一次的大韩民国宪法定期检诊制度，通过国会在大选后组建50人开宪特委、3年国民意见收集及50万人以上国民请愿机制来实现。",
      "source": "https://www.ohmynews.com/NWS_Web/View/at_pg.aspx?CNTN_CD=A0003169501"
    },
    {
      "date": "2025",
      "topic": "气候危机应对",
      "stance_content": "代表发起了《碳中立绿色增长基本法》修正案，主张将绿色产业范围具体化，推动国家制定中长期培育战略，使政策从单一的温室气体减排扩展到气候灾难应对。主张国会层面制度规制与市民层面的实践活动并行推进。",
      "source": "https://www.ntoday.co.kr/news/articleView.html?idxno=123190"
    },
    {
      "date": "2025-09",
      "topic": "国民年金改革",
      "stance_content": "发起《国民年金法》修正案，主张国民年金运营管理费应由国家全额承担（税收），而非使用缴纳者的年金资金来运营，以增强年金制度的可持续性。",
      "source": "https://www.ohmynews.com/NWS_Web/View/at_pg.aspx?CNTN_CD=A0003169501"
    },
    {
      "date": "2025-07",
      "topic": "公职选举制度改革",
      "stance_content": "发起《公职选举法》修正案，主张将高层及政务职公务员及检察官、法官的参选限制期从原来的90日延长至1年，以防止检政旋转门现象。",
      "source": "http://www.kdpress.co.kr/news/articleView.html?idxno=130367"
    },
