  "political_stances": [
    {
      "date": "2024-06",
      "topic": "半导体产业与地方发展",
      "stance_content": "积极推动在龟尾建设'尖端半导体综合体'，主张强化半导体材料·零件·装备（소부장）企业的政府补贴与扶持政策，致力于将龟尾打造为半导体核心城市。主张非首都圈中小装备企业也应获得政府研发支持。",
      "source": "https://www.gmilbo.net/mobile/article.html?no=73632"
    },
    {
      "date": "2025-06",
      "topic": "反全租诈骗与住房保障",
      "stance_content": "主导发起了'全租诈骗防止三法'，主张在合同签订前向租客提供关键不动产信息以预防全租诈骗，强化公认中介师管理制度，扩大竞拍·公卖程序缓期适用范围，全方位保护租客权益。",
      "source": "https://www.kmsnews.co.kr/news/articleView.html?idxno=25575"
    },
    {
      "date": "2025-08",
      "topic": "地方人口衰减应对",
      "stance_content": "发起修改《地方自治分权及地域均衡发展特别法》，主张将道农复合型市所属的邑·面地区也纳入人口减少地区指定范围，使农村地区能够获得政府的政策与财政支持，应对地方小城市人口外流问题。",
      "source": "https://www.straightnews.co.kr/news/articleView.html?idxno=279401"
    },
    {
      "date": "2025-07",
      "topic": "国会人事制度改革",
      "stance_content": "发起'宋美铃防止法'（国会法及国家公务员法修正案），要求政权交替后留任的部长也必须接受国会人事听证会，填补制度漏洞以增强政府高官的问责机制。",
      "source": "http://www.gbpolitics.com/news/view.php?idx=220363"
    }
  ],
