  "political_stances": [
    {
      "topic": "劳工权益保障",
      "stance_content": "作为现代汽车工厂工人出身的国会议员，长期致力于维护劳工权益，主张强化劳动者结社权、集体谈判权和集体行动权，反对过度劳动和过劳死现象。",
      "date": "2024-06",
      "source": "韩国议会资料及媒体报道"
    },
    {
      "topic": "全租诈骗与住房政策",
      "stance_content": "主导推动《全租诈骗受害者支援及居住安定特别法》修正案，主张将全租诈骗定性为社会性灾难，要求扩大受害者认定范围、引入保证金先付制度、延长特别法有效期，保障受害者最低三分之一的保证金返还。",
      "date": "2025-11",
      "source": "蔚山每日日报 (https://ujnews.co.kr/news/newsview.php?ncode=1065575966732135)"
    },
    {
      "topic": "国家安全法废除",
      "stance_content": "2025年12月作为共同发起人提出《国家安全法废除法案》，主张该法继承自日本帝国主义治安维持法，78年来被用作思想镇压和权力维稳工具，应当彻底废止以完成真正的民主共和制。",
      "date": "2025-12-01",
      "source": "OhMyNews (https://www.ohmynews.com/NWS_Web/View/at_pg.aspx?CNTN_CD=A0003187615)"
    },
    {
      "topic": "进步政治与选举制度改革",
      "stance_content": "主张扩大比例代表制比例、引入中选区制等选举制度改革，认为应将蔚山市民给予小党的支持扩展至全国层面，推动进步政治在全国的发展。",
      "date": "2024-04",
      "source": "韩国日报 (https://www.hankookilbo.com/news/article/A2024041114420000142)"
    },
    {
      "topic": "12·3内乱追究",
      "stance_content": "代表发起《12·3紧急戒严等内乱行为真相查明及主谋等处罚特别法案》，主张彻底追究尹锡悦政府发动内乱的责任。",
      "date": "2025",
      "source": "Pollite (https://www.pollite.kr/member/%EC%9C%A4%EC%A2%85%EC%98%A4)"
    }
