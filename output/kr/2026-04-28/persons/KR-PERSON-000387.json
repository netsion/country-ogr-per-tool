  "political_stances": [
    {
      "date": "2023-05",
      "topic": "接壤地区经济发展与和平经济特区",
      "stance_content": "金成愿是《和平经济特区法》（原名《统一经济特区法》）的核心推动者，主张在朝鲜接壤地区设立和平经济特区，通过国家层面的开发、企业入驻、基础设施扩充来促进接壤地区经济发展，解决接壤地区因国家安全限制长期遭受的'逆向歧视'问题。该法案历经7年，于2023年5月通过国会本会议。",
      "source": "韩语维基百科 (https://ko.wikipedia.org/wiki/%EA%B9%80%EC%84%B1%EC%9B%90_(%EC%A0%95%EC%B9%98%EC%9D%B8))"
    },
    {
      "date": "2017-05",
      "topic": "京畿北部分道（分道设治）",
      "stance_content": "积极推动京畿道北部分离设立'京畿北道'，认为京畿北部地区在经济圈、生活圈及区域特征上与南部截然不同，长期被忽视。2017年5月代表发起《京畿北道设置法》，此后持续将该议题作为核心选举公约。",
      "source": "News1 (https://www.news1.kr/local/gyeonggi/2999228)"
    },
    {
      "date": "2020-02",
      "topic": "能源政策 - 核能与新能源双轨并行",
      "stance_content": "主张能源政策应采取'核能与新能源双轨并行'（투트랙）战略，既发展核电也推进新能源，反对文在寅政府的脱核电政策，认为企业活动限制性法规应松绑，必要监管应交给产业界自主。",
      "source": "ET News (https://www.etnews.com/20200206000170)"
    },
    {
      "date": "2025-07",
      "topic": "国家基干电力网扩建",
      "stance_content": "2025年7月主办'国家竞争力确保—国家基干核心电力网构建战略'政策讨论会，主张建立合理的地下化标准和明确的补偿体系以加快电力网扩建，认为电力基础设施是国家竞争力的核心要素。",
      "source": "Energy Time News (http://www.enertopianews.co.kr/news/articleView.html?idxno=52705)"
    },
    {
      "date": "2025-09",
      "topic": "反对设立气候能源环境部",
      "stance_content": "明确反对政府推进的'气候能源环境部'新设方案，批评此举将动摇国家能源安全和产业竞争力，要求立即重新审视该仓促改组方案。",
      "source": "Law Issue (https://www.lawissue.co.kr/view.php?ud=20250908194956583392eef753eb_12)"
    },
    {
      "date": "2025-06",
      "topic": "党内改革与保守重建",
      "stance_content": "2025年6月宣布参选国民力量党院内代表，提出'反省过去过失、开启新保守'的口号，强调党内民主主义是当务之急，主张以'水恢复心恢复'为旗号推动党的实用化和外延扩张。",
      "source": "联合新闻 (https://www.yna.co.kr/view/AKR20250612075200001)"
    }
  ],
