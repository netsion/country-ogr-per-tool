  "political_stances": [
    {
      "date": "2024-08",
      "topic": "体育界弊端改革",
      "stance_content": "以2024年巴黎奥运会安世永选手的爆料为契机，开设'体育界弊端国民举报中心'，主张从根本上解决体育界的结构性弊端，包括暴力、不公正选拔、体罚等问题。2025年8月又启动第二期举报中心，同时扩展至文化艺术界的不公正行为。",
      "source": "联合新闻、中央日报"
    },
    {
      "date": "2025-11",
      "topic": "学校体育振兴 - 一名学生一个体育俱乐部",
      "stance_content": "主导提出《学校体育振兴法》部分修订案（'1学生1体育俱乐部法'），要求学校校长有义务让学生参与至少一个学校体育俱乐部，旨在增强学生体质并培养运动习惯。",
      "source": "联合新闻 (https://www.yna.co.kr/view/AKR20251106053400007)"
    },
    {
      "date": "2025-12",
      "topic": "生活体育指导者待遇改善",
      "stance_content": "主张生活体育指导者是国民健康的公共服务最前线，提出改善其待遇的立法方案，强调可持续的生活体育需要专业人士获得尊重的基本条件。",
      "source": "NewsBom (http://www.newsbom.co.kr/news/articleView.html?idxno=15010)"
    },
    {
