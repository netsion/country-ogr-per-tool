  "political_stances": [
    {
      "date": "2026-04",
      "topic": "行政首都世宗完成立法",
      "stance_content": "作为'行政首都完成四法'（世宗特别市法、行政首都特别法、国会全部迁移法、大法院全部迁移法）的主要发起人，主张通过立法将世宗市建设为完整的行政首都。指出行政二元化每年造成超过5万亿韩元的社会成本，强调22年前宪法法院对新城行政首都特别法的违宪判决所依据的社会条件已发生根本变化，应通过重新立法和宪法法院裁决来完成行政首都建设。",
      "source": "世宗之声 (https://www.sjsori.com/news/articleView.html?idxno=85512)"
    },
    {
      "date": "2026-04",
      "topic": "世宗城市发展定位与产业创新",
      "stance_content": "提出世宗市不应局限于'行政城市'定位，应向'创新城市'和'亚洲枢纽'转型。主张建设'世宗谷'（세종밸리）打造创业生态，推动中美冲突大转换期下的'亚洲伙伴关系'战略，将世宗建设为国际外交团地、全球文化特区，并通过忠清圈广域快速铁路（CTX）十字网络和KTX网络连接全国，实现2小时生活圈。",
      "source": "忠清新闻 (https://www.ccnnews.co.kr/news/articleView.html?idxno=404007)"
    },
    {
      "date": "2025-11",
      "topic": "重返共同民主党的可能性",
      "stance_content": "首次公开回应重返共同民主党（더불어민주당）的可能性，表示'民主党的我故乡'，个人意愿上希望复党，但强调复党是否有利于世宗发展、行政首都完成以及民主党的地方选举胜利才是关键判断标准，承诺在定期国会结束后听取世宗市民和民主党党员的意见再做决定。",
      "source": "联合新闻 (https://www.fnnews.com/news/202511201331345922)"
    },
    {
      "date": "2024-03",
      "topic": "世宗地方法院设立法案",
      "stance_content": "作为世宗甲选区候选人推动世宗地方法院设立法案，主张世宗特别自治市作为行政中心城市应拥有独立的司法管辖权，法案当时在国会立法司法委员会第一小委员会待审。",
      "source": "亚洲经济 (https://cm.asiae.co.kr/article/2024032413343750404)"
    }
  ],
