  "political_stances": [
    {
      "date": "2023-07",
      "topic": "韩美同盟与外交安全",
      "stance_content": "作为第21代国会外交统一委员会委员长，金台镐强调韩美同盟是韩国外交与安全的根基，称其为血盟关系。主张强化韩美同盟关系，积极推动韩美日三边安全合作，认为韩美日首脑会议将为韩国参与G7打开道路。反对安美经中（安全靠美国、经济靠中国）的暧昧立场，主张在中美博弈中坚定站在美国一边。",
      "source": "朝鲜日报专访 / 国会外交统一委员会活动"
    },
    {
      "date": "2023-06",
      "topic": "对朝政策与核问题",
      "stance_content": "将朝核问题列为韩美同盟面临的最大挑战，主张以强硬立场应对朝鲜核威胁，支持通过国际合作加强制裁与施压，与国民力量党的保守安全观一致。",
      "source": "世界日报专访"
    },
    {
      "date": "2020-07",
      "topic": "行政首都迁移与地方分权",
      "stance_content": "主张将总统府（青瓦台）和国会迁至行政首都世宗市，认为只有完成包括教育机构和国立大学在内的全面迁移，才能真正实现地方分权与国家均衡发展。",
      "source": "京乡新闻采访"
    },
    {
      "date": "2024-03",
      "topic": "地方医疗与民生",
      "stance_content": "将梁山市熊上中央医院的重新开业和熊上地区公共医院设立作为最优先竞选承诺，致力于解决因医院关闭导致的地区急救医疗空白问题。当选后持续推动熊上中央百医院重新开业，2025年实现医院以新名称重新开张。",
      "source": "朝鲜日报 / 庆南新闻"
    },
    {
      "date": "2025-08",
      "topic": "党内改革与政治革新",
      "stance_content": "在国民力量党内被视为温和改革派，与亲尹锡悦的主流路线保持一定距离，主张党内渐进式变革和路线更新，强调务实政治而非对抗政治。",
      "source": "庆南道民日报专栏"
    }
  ],
