  "political_stances": [
    {
      "date": "2024",
      "topic": "外交与韩中关系",
      "stance_content": "主张务实平衡的外交路线，强调韩中关系的重要性，作为韩中议员联盟事务总长积极推动两国议会交流。认为韩国应在中美之间保持战略自主，不应盲目追随美国。在中国工作多年，被誉为「中国通」，主张通过对话与合作管控韩中分歧。",
      "source": "월간조선 인터뷰, 한중의원연맹 활동"
    },
    {
      "date": "2022",
      "topic": "居住福祉与住房政策",
      "stance_content": "担任共同民主党居住福祉特别委员会委员长期间，积极推动住房保障政策，关注民众住房困难。曾被经济正义实践市民联合评选为不动产·建设领域改革立法前三名议员，致力于住房市场的公平与稳定。",
      "source": "경제정의실천시민연합 평가, 더불어민주당 주거복지특별위원회"
    },
    {
      "date": "2025-09",
      "topic": "尖端产业与对华竞争战略",
      "stance_content": "关注韩国在AI、半导体等尖端产业领域的竞争力，主张在应对中国技术崛起的同时寻求合作空间。2025年9月主持相关研讨会，强调韩国需要在尖端技术领域实现「再飞跃」。",
      "source": "뉴스1, 파이낸셜뉴스 보도 (2025.09)"
    },
    {
      "date": "2024-12",
      "topic": "国家安全与戒严法改革",
      "stance_content": "2024年12月3日戒严事件后，积极推动戒严法修正案，主张严格限制总统戒严权滥用，强化国会对戒严令的制衡机制，是戒严法改革的主要发起者之一。",
      "source": "대표발의안: 계엄법 일부개정법률안"
    }
  ],
