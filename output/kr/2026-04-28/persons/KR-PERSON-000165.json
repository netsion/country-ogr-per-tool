  "political_stances": [
    {
      "date": "2024",
      "topic": "检察改革",
      "stance_content": "长期主张检警搜查权分离，认为仅警察应拥有搜查权，是韩国推动检警改革的核心人物。批评政府检察改革方案为检察权复辟，要求彻底瓦解检方垄断搜查与起诉权的体制。",
      "source": "https://www.youtube.com/@hwang_unha"
    },
    {
      "date": "2024",
      "topic": "行政首都建设",
      "stance_content": "积极推动行政首都完全迁移至世宗，主张加速政府机构搬迁，完善世宗的基础设施和交通网络，实现地区均衡发展。曾发起《行政首都建设特别法》。",
      "source": "https://www.pollite.kr/member/%ED%99%A9%EC%9A%B4%ED%95%98"
    },
    {
      "date": "2025",
      "topic": "多党制与联合政治",
      "stance_content": "主张突破两党制弊端，推进多党制联合政治，认为祖国革新党应在韩国政治版图中扮演核心第三势力角色，推动政治现代化。反对被大党吸收合并。",
      "source": "https://www.dailian.co.kr/news/view/1603995"
    },
    {
      "date": "2025",
      "topic": "司法公正",
      "stance_content": "强烈批评尹锡悦政府的司法运作，主张追究政治检察官的责任，推动司法机构人事改革，实现司法民主化。要求公布政治检察官名单。",
      "source": "https://news.kbs.co.kr/news/pc/view/view.do?ncd=8084744"
    }
  ],
