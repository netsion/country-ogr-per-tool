  "political_stances": [
    {
      "date": "2026-04",
      "topic": "大邱市长选举 - 大邱大转换5大政策",
      "stance_content": "提出'大邱大转换5大政策'核心纲领，包括：引进三星半导体工厂、引进三星医院分院、构建大邱型AI产业生态系统、吸引年轻人口回流、建设全球型大邱。主张'大邱的生存需要大胆决断'，批评大邱过去十年经济停滞，提出以半导体和医疗产业为双引擎推动大邱经济再造。",
      "source": "每日经济 (https://www.hankyung.com/article/2026020939847)"
    },
    {
      "date": "2026-04",
      "topic": "大邱市长选举 - 拒绝保守阵营单一化",
      "stance_content": "明确表态'绝对不会有单一化'，拒绝与无党籍候选人（如前国会副议长朱浩荣、前放送通信委员长李真淑）进行保守阵营整合，强调'公党程序的正当性'，主张通过正式的党内竞选程序产生候选人。即使成为最终候选人也不会与无党籍候选人单一化，以'判断权交给市民'为立场。",
      "source": "庆北日报 (https://www.kyongbuk.co.kr/news/articleView.html?idxno=4070390)"
    },
    {
      "date": "2026-02",
      "topic": "政治定位 - 以自身政治接受评价",
      "stance_content": "宣布大邱市长参选时表示'现在是作为政治人柳荣夏独自站立的出发点'，明确表达脱离朴槿惠阴影、以自身政治能力接受评价的意愿，同时提出'超越阵营和理念，与政府·执政党人士建立的人脉网络将为大邱所用'。",
      "source": "中央日报 (https://www.joongang.co.kr/article/25403704)"
    },
    {
      "date": "2025-05",
      "topic": "总统选举 - 国民力量党竞选阵营",
      "stance_content": "在第21届总统选举中担任国民力量党金文洙候选人大邱选举对策委员会清廉选举对策本部长，负责大邱地区选举清廉与公正性保障工作。",
      "source": "韩语维基百科 (https://ko.wikipedia.org/wiki/%EC%9C%A0%EC%98%81%ED%95%98)"
