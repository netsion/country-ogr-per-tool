  "political_stances": [
    {
      "date": "2022-05",
      "topic": "对朝政策",
      "stance_content": "主张对朝政策应超越政权更替保持连续性，提出\"接力赛\"式对朝政策理念，强调应在历任政府积累的基础上叠加新政府的哲学。主张南北关系正常化，致力于推动超党派的对朝政策。对朝散发传单虽持反对态度，但认为应从自由主义角度审视相关法规，重视朝鲜居民知情权。",
      "source": "统一部长官人事听证会 / 新闻报道"
    },
    {
      "date": "2022-07",
      "topic": "外交安全政策",
      "stance_content": "强调韩美同盟为核心，同时重视韩中关系，主张在国际社会支持下推进对朝政策。担任驻华大使期间积累了丰富的对华外交经验，认为韩中关系应在互相尊重的基础上设定合理边界。",
      "source": "统一部长官就职演说 / 媒体采访"
    },
    {
      "date": "2023-05",
      "topic": "统一政策",
      "stance_content": "主张建立\"可持续的统一与对朝政策基础\"，提出朝鲜问题是不可持续的现状，呼吁朝鲜走变化与开放之路。推动\"大胆构想\"（Bold Initiative）对朝政策框架，强调以无核化为前提的经济合作方案。",
      "source": "VOA专访 / RFA采访"
    },
    {
      "date": "2022-05",
      "topic": "朝鲜人权",
      "stance_content": "主张公开朝鲜人权实态信息，引导国际社会施压。认为朝鲜居民接触外部信息对体制存续也有利，支持朝鲜居民的知情权。",
      "source": "VOA韩国专访"
    }
  ],
