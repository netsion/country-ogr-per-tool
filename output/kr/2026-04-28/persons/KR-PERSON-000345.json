  "political_stances": [
    {
      "date": "2024-06",
      "topic": "商法改革与股东权益保护",
      "stance_content": "作为国会代表发议人提出商法修改案（第22届国会第1号法案），主张将公司董事的忠实义务对象从仅限公司扩展至全体股东，引入'3%规则'限制最大股东在监查委员选举中的表决权。该法案被称为'李在明政府一号民生法案'，于2025年7月经朝野协商后在国会通过。",
      "source": "国会立法追踪 / 新闻报道"
    },
    {
      "date": "2025",
      "topic": "全南光州行政合并",
      "stance_content": "积极推动全罗南道与光州广域市的行政合并，主张建立'全南光州超广域特别自治道'，认为合并是打破首都圈一极体制、形成新国家增长轴的关键。2025年11月首次提出相关特别法案，2026年3月经国会全体会议通过，全南光州将于2026年7月完成全国首个行政合并。",
      "source": "namu.wiki / 新闻报道"
    },
    {
      "date": "2025",
      "topic": "湖南地区交通基础设施改善",
      "stance_content": "致力于改善湖南地区（光州全南）交通基础设施，推动湖南高速公路扩建工程开工、湖南线高铁座位增编与运费折扣扩大、KTX与SRT整合等议题。促成湖南线十年来首次增编和座位扩容，以及KTX-山川部分列车延伸至光州松汀站运行。",
      "source": "namu.wiki / 联合新闻报道"
    },
    {
      "date": "2024",
      "topic": "地区发展与财政保障",
      "stance_content": "在国会国土交通委员会中积极为光州北区争取国费预算，2026年度政府预算案中成功争取光州北区地区发展预算2123亿韩元，包括光州城市铁道2号线建设1665亿韩元、湖南高速公路扩建238亿韩元等重大项目。",
      "source": "新闻报道 / Daum新闻"
    }
  ],
